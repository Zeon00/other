local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- hapus gui lama
if playerGui:FindFirstChild("AutoGraveGUI") then
	playerGui.AutoGraveGUI:Destroy()
end

-- remote
local digRemote = ReplicatedStorage:WaitForChild("Packages")
	:WaitForChild("Knit")
	:WaitForChild("Services")
	:WaitForChild("GraveDiggerService")
	:WaitForChild("RF")
	:WaitForChild("DigGrave")

local gravesFolder = Workspace:WaitForChild("GameObjects"):WaitForChild("GraveDigging")

local autoDig = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "AutoGraveGUI"
gui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,200,0,110)
frame.Position = UDim2.new(0,300,0,200)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Parent = gui

-- title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,25)
title.BackgroundColor3 = Color3.fromRGB(40,40,40)
title.Text = "Auto Grave Digger"
title.TextColor3 = Color3.new(1,1,1)
title.Parent = frame

-- toggle
local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(1,-20,0,40)
toggle.Position = UDim2.new(0,10,0,35)
toggle.Text = "Auto Dig : OFF"
toggle.BackgroundColor3 = Color3.fromRGB(200,60,60)
toggle.TextColor3 = Color3.new(1,1,1)
toggle.Parent = frame

-- minimize
local minimize = Instance.new("TextButton")
minimize.Size = UDim2.new(0,30,0,25)
minimize.Position = UDim2.new(1,-60,0,0)
minimize.Text = "-"
minimize.Parent = frame

-- close
local close = Instance.new("TextButton")
close.Size = UDim2.new(0,30,0,25)
close.Position = UDim2.new(1,-30,0,0)
close.Text = "X"
close.Parent = frame

-- icon saat minimize
local icon = Instance.new("TextButton")
icon.Size = UDim2.new(0,60,0,60)
icon.Position = UDim2.new(0,20,0,200)
icon.Text = "DIG"
icon.Visible = false
icon.BackgroundColor3 = Color3.fromRGB(40,40,40)
icon.TextColor3 = Color3.new(1,1,1)
icon.Parent = gui

-- toggle
toggle.MouseButton1Click:Connect(function()
	autoDig = not autoDig
	
	if autoDig then
		toggle.Text = "Auto Dig : ON"
		toggle.BackgroundColor3 = Color3.fromRGB(60,200,60)
	else
		toggle.Text = "Auto Dig : OFF"
		toggle.BackgroundColor3 = Color3.fromRGB(200,60,60)
	end
end)

-- minimize
minimize.MouseButton1Click:Connect(function()
	frame.Visible = false
	icon.Visible = true
end)

icon.MouseButton1Click:Connect(function()
	frame.Visible = true
	icon.Visible = false
end)

-- destroy gui
close.MouseButton1Click:Connect(function()
	autoDig = false
	gui:Destroy()
end)

-- draggable
local dragging = false
local dragInput
local dragStart
local startPos

local function update(input)
	local delta = input.Position - dragStart
	frame.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
end

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

title.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		update(input)
	end
end)

-- auto dig loop
task.spawn(function()
	while task.wait(0.25) do
		if autoDig then
			for _,grave in pairs(gravesFolder:GetChildren()) do
				pcall(function()
					digRemote:InvokeServer(grave)
				end)
			end
		end
	end
end)
