-- Universal Multi-Village Auto Attack
-- Scans all folders in WorldMobs and attacks the closest valid enemy.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

-- Wait for the main folder
local WorldMobs = workspace:WaitForChild("Server"):WaitForChild("WorldMobs")
local Bridge = ReplicatedStorage:WaitForChild("Bridge")

-- Configuration
local Toggled = false
local AttackConnection = nil

-- FUNCTION: Find the closest enemy in ANY village
local function getClosestTarget()
    local Character = Player.Character or Player.CharacterAdded:Wait()
    local HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
    
    if not HumanoidRootPart then return nil end

    local closestDistance = math.huge
    local closestMob = nil

    -- 1. Loop through all Villages (Folders inside WorldMobs)
    for _, villageFolder in pairs(WorldMobs:GetChildren()) do
        if villageFolder:IsA("Folder") then
            -- 2. Loop through all items inside the village
            for _, potentialMob in pairs(villageFolder:GetChildren()) do
                
                -- 3. Check if it is a valid Enemy
                -- Checks if it is a Model AND has a Humanoid (Alive)
                if potentialMob:IsA("Model") then
                    local mobHumanoid = potentialMob:FindFirstChild("Humanoid")
                    local mobHRP = potentialMob:FindFirstChild("HumanoidRootPart")

                    if mobHumanoid and mobHRP and mobHumanoid.Health > 0 then
                        -- Calculate Distance
                        local distance = (HumanoidRootPart.Position - mobHRP.Position).Magnitude
                        
                        -- Update closest if this one is nearer
                        if distance < closestDistance then
                            closestDistance = distance
                            closestMob = potentialMob
                        end
                    end
                end
            end
        end
    end

    return closestMob
end

-- FUNCTION: The Attack Loop
local function attackLoop()
    if not Toggled then return end

    local target = getClosestTarget()

    if target then
        -- Update GUI text to show who we are attacking
        if ScreenGui:FindFirstChild("MainFrame") then
            ScreenGui.MainFrame.StatusLabel.Text = "Target: " .. target.Name
        end

        -- Fire the attack
        local args = {
            "Attack",
            "Click",
            target
        }
        Bridge:FireServer(unpack(args))
    else
         -- Update GUI text if no target found
         if ScreenGui:FindFirstChild("MainFrame") then
            ScreenGui.MainFrame.StatusLabel.Text = "Target: Searching..."
        end
    end
end

