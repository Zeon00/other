local enabled = false

-- LOOP FARM MADERA
task.spawn(function()
    while task.wait() do
        if enabled then
            local enemies = workspace:WaitForChild("RaidArenas")
                :WaitForChild("World1")
                :WaitForChild("Enemies")

            local char = game.Players.LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if hrp then
                for _, enemyFolder in pairs(enemies:GetChildren()) do
                    for _, mob in pairs(enemyFolder:GetChildren()) do
                        local root = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Torso")

                        if root then
                            hrp.CFrame = root.CFrame + Vector3.new(0, 3, 0)
                            task.wait(0.2)
                        end
                    end
                end
            end
        end
    end
end)

