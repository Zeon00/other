--// KILL AURA (tetep jalan di dungeon)
local function GetEnemies()
    local t = {}
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and string.find(v.Name,"NPC") then
            local hrp = v:FindFirstChild("HumanoidRootPart")
            local hum = v:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                table.insert(t, hrp)
            end
        end
    end
    return t
end

task.spawn(function()
    while true do
        if aura then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                for _,hrp in pairs(GetEnemies()) do
                    if (root.Position - hrp.Position).Magnitude <= 30 then
                        for i=1,3 do
                            pcall(function() Damage:FireServer() end)
                        end
                    end
                end
            end
        end
        task.wait(0.05)
    end
end)

--// AUTO TP (FIX)
task.spawn(function()
    while true do
        if tp and not _G.InDungeon and not getgenv().AutoDungeon then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            local npc = workspace:FindFirstChild("NPCs")

            if root and npc then
                local stageFolder = npc:FindFirstChild("StageEnemies")
                if stageFolder then
                    for _, stage in pairs(stageFolder:GetChildren()) do
                        for _, mob in pairs(stage:GetChildren()) do
                            if mob:IsA("Model") then
                                local hrp = mob:FindFirstChild("HumanoidRootPart")
                                local hum = mob:FindFirstChild("Humanoid")

                                if hrp and hum and hum.Health > 0 then
                                    root.CFrame = CFrame.new(hrp.Position + Vector3.new(0,0,3), hrp.Position)
                                    task.wait(2)
                                end
                            end
                        end
                    end
                end
            end
        end
        task.wait(2)
    end
end)

--// AUTO DUNGEON CORE
DungeonEvent.OnClientEvent:Connect(function(action)
    if action == "Open" then
        DungeonReady = true
    elseif action == "SetupGUI" then
        _G.InDungeon = true
    elseif action == "ShowEndRewards" then
        _G.InDungeon = false
        DungeonReady = false
    end
end)

task.spawn(function()
    while true do
        if getgenv().AutoDungeon and DungeonReady then
            DungeonReady = false

            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local pos = RS.PlotTeleportLocations.Dungeons.Position

                -- TP ke dungeon
                TPDungeon:FireServer(pos, char.HumanoidRootPart.CFrame.Rotation.Y)

                task.wait(3)

                -- Start dungeon
                DungeonEvent:FireServer("StartDungeon")
            end
        end
        task.wait(1)
    end
end)

--// DRAG
local dragging, dragInput, dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

main.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateDrag(input)
    end
end)

