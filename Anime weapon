--// CREATE ITEM BUTTON
local function createItem(name)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(1,0,0,30)
    btn.Text = "☐ "..name
    btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    btn.TextColor3 = Color3.fromRGB(210,210,210)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 13
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

    SelectedItems[name] = false

    btn.MouseButton1Click:Connect(function()
        SelectedItems[name] = not SelectedItems[name]

        if SelectedItems[name] then
            btn.Text = "☑ "..name
            btn.BackgroundColor3 = Color3.fromRGB(60,140,80)
        else
            btn.Text = "☐ "..name
            btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        end
    end)
end

--// LOAD ITEMS
local function loadItems()
    local success, data = pcall(function()
        return GetShop:InvokeServer()
    end)

    if not success then return end

    for _, items in pairs(data) do
        for _, item in pairs(items) do
            if not SelectedItems[item.itemName] then
                createItem(item.itemName)
            end
        end
    end
end

