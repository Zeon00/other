--// KILL AURA (TETEP)
local function GetEnemies()
    local t = {}
    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and string.find(v.Name,"NPC") then
            local hrp = v:FindFirstChild("HumanoidRootPart")
            local hum = v:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                table.insert(t, hrp)
            end
        end
    end
    return t
end

task.spawn(function()
    while true do
        if aura then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                for _,hrp in pairs(GetEnemies()) do
                    if (root.Position - hrp.Position).Magnitude <= 30 then
                        pcall(function()
                            for i = 1,3 do
                                Damage:FireServer()
                            end
                        end)
                    end
                end
            end
        end
        task.wait(0.05)
    end
end)

task.spawn(function()
    while true do
        if tp then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")

            if root then
                local npc = workspace:FindFirstChild("NPCs")
                if npc then
                    local stageFolder = npc:FindFirstChild("StageEnemies")
                    if stageFolder then

                        local closestStage = nil
                        local closestDist = math.huge

                        -- cari stage terdekat dari player
                        for _, stage in pairs(stageFolder:GetChildren()) do
                            local mobs = stage:GetChildren()
                            for _, mob in pairs(mobs) do
                                if mob:IsA("Model") then
                                    local hrp = mob:FindFirstChild("HumanoidRootPart")
                                    local hum = mob:FindFirstChild("Humanoid")

                                    if hrp and hum and hum.Health > 0 then
                                        local dist = (root.Position - hrp.Position).Magnitude
                                        if dist < closestDist then
                                            closestDist = dist
                                            closestStage = stage
                                        end
                                    end
                                end
                            end
                        end

                        -- kalau nemu stage terdekat → cuma loop stage itu
                        if closestStage then
                            for _, mob in pairs(closestStage:GetChildren()) do
                                if not tp then break end

                                if mob:IsA("Model") then
                                    local hrp = mob:FindFirstChild("HumanoidRootPart")
                                    local hum = mob:FindFirstChild("Humanoid")

                                    if hrp and hum and hum.Health > 0 then
                                        root.CFrame = CFrame.lookAt(
                                            hrp.Position + Vector3.new(0,0,3),
                                            hrp.Position
                                        )

                                        task.wait(2.08)
                                    end
                                end
                            end
                        end

                    end
                end
            end
        end

        task.wait(2.1)
    end
end)

