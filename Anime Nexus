end)

-- main loop (non combat)
RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local egg = getEgg()

    if FastWalk and hum then
        hum.WalkSpeed = 35
    elseif hum then
        hum.WalkSpeed = 16
    end

    if AutoTP and egg then
        tpEgg(egg)
    end

    if AutoHatch and egg then
        task.spawn(function()
            tpEgg(egg)
            task.wait(0.1)
            openEgg(egg.Name)
        end)
    end
end)

