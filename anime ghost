-- TOGGLES
local function Toggle(txt,y,cb)
    local b=Instance.new("TextButton",main)
    b.Size=UDim2.new(1,-20,0,30)
    b.Position=UDim2.new(0,10,0,y)
    b.Text=txt.." OFF"
    local s=false
    b.MouseButton1Click:Connect(function()
        s=not s
        b.Text=txt.." "..(s and "ON" or "OFF")
        cb(s)
    end)
end

