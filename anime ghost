-- TOGGLE
local function Toggle(name,pos)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(1,-20,0,30)
    btn.Position = UDim2.new(0,10,0,pos)
    btn.Text = name.." OFF"
    btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn)

    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name.." "..(state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(0,170,0) or Color3.fromRGB(60,60,60)

        if name=="AutoRaid" then AutoRaid=state end
        if name=="Aura" then Aura=state end
        if name=="TP" then TP=state end
    end)
end

Toggle("AutoRaid",110)
Toggle("Aura",145)
Toggle("TP",180)

