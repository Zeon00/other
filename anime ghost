--// MAP
local RaidMap = workspace:WaitForChild("_MAP"):WaitForChild("Gamemode"):WaitForChild("Easter Raid_8594485805")
local SpawnPart = RaidMap:WaitForChild("Spawn")

--// ENEMY
local EnemyFolder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")

--// SETTINGS
local AutoRaid, Aura, TP = false, false, false
local RAID_COOLDOWN = 900

local lastRaidTime = 0
local raidState = "Idle"
local lastTP = 0

--// START RAID
local function StartRaid()
    pcall(function()
        RaidRemote:FireServer({
            {
                "GamemodeSystem",
                "Start",
                "Easter Raid",
                8594485805,
                n = 4
            },
            "\002"
        })
    end)
end

--// STATE DETECT
local function GetRaidState()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then
        return "Idle"
    end

    local dist = (char.HumanoidRootPart.Position - SpawnPart.Position).Magnitude

    if dist < 80 then
        if #EnemyFolder:GetChildren() > 0 then
            return "InRaid"
        else
            return "Waiting"
        end
    end

    return "Idle"
end

--// UPDATE STATE
task.spawn(function()
    while task.wait(1) do
        local newState = GetRaidState()

        if raidState == "InRaid" and newState == "Idle" then
            lastRaidTime = tick()
        end

        raidState = newState
    end
end)

--// AUTO RAID LOOP
task.spawn(function()
    while task.wait(2) do
        if AutoRaid and raidState == "Idle" then
            local passed = tick() - lastRaidTime

            if passed >= RAID_COOLDOWN then
                StartRaid()
                task.wait(1)

                -- TP ke spawn
                pcall(function()
                    local char = player.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        char.HumanoidRootPart.CFrame = SpawnPart.CFrame + Vector3.new(0,5,0)
                    end
                end)

                task.wait(12)
            end
        end
    end
end)

--// GET NEAREST
local function GetNearest()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local root = char.HumanoidRootPart
    local nearest, dist = nil, math.huge

    for _,mob in pairs(EnemyFolder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - root.Position).Magnitude
            if d < dist then
                dist = d
                nearest = hrp
            end
        end
    end

    return nearest
end

--// TP
local function TPTo(hrp)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    if tick() - lastTP < 0.2 then return end
    lastTP = tick()

    char.HumanoidRootPart.CFrame =
        char.HumanoidRootPart.CFrame:Lerp(hrp.CFrame * CFrame.new(0,0,4), 0.6)
end

--// LOOP TP
task.spawn(function()
    while task.wait(0.2) do
        if TP and raidState == "InRaid" then
            local t = GetNearest()
            if t then TPTo(t) end
        end
    end
end)

