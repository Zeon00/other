--// ENEMY
local EnemyFolder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")

--// SETTINGS
local AutoRaid, Aura, TP = false, false, false
local RAID_DURATION = 900

local raidState = "Idle"
local raidStartTime = 0
local lastTP = 0

--// SAFE GET NPC
local NPC
task.spawn(function()
    repeat task.wait() until workspace:FindFirstChild("_MAP")
    repeat task.wait() until workspace._MAP:FindFirstChild("Easter 2026 Event")
    repeat task.wait() until workspace._MAP["Easter 2026 Event"]:FindFirstChild("Interactions")
    repeat task.wait() until workspace._MAP["Easter 2026 Event"].Interactions:FindFirstChild("Gamemode")
    repeat task.wait() until workspace._MAP["Easter 2026 Event"].Interactions.Gamemode:FindFirstChild("EasterLevi")
    repeat task.wait() until workspace._MAP["Easter 2026 Event"].Interactions.Gamemode.EasterLevi:FindFirstChild("HumanoidRootPart")

    NPC = workspace._MAP["Easter 2026 Event"].Interactions.Gamemode.EasterLevi.HumanoidRootPart
end)

--// SAFE GET SPAWN
local function GetSpawn()
    local map = workspace:FindFirstChild("_MAP")
    if not map then return end

    local gm = map:FindFirstChild("Gamemode")
    if not gm then return end

    local raid = gm:FindFirstChild("Easter Raid_8594485805")
    if not raid then return end

    return raid:FindFirstChild("Spawn")
end

--// TP
local function TP_RAID(cf)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = cf
    end
end

--// CREATE RAID
local function CreateRaid()
    RemoteEvent:FireServer({
        {
            "GamemodeSystem",
            "Create",
            "Easter Raid",
            "ChocolateKingdom",
            "Easy",
            true,
            n = 6
        },
        "\002"
    })
end

--// START RAID
local function StartRaid()
    RemoteEvent:FireServer({
        {
            "GamemodeSystem",
            "Start",
            "Easter Raid",
            8594485805,
            n = 4
        },
        "\002"
    })
end

--// STATE DETECT
local function GetState()
    local spawn = GetSpawn()
    local char = player.Character

    if not spawn or not char or not char:FindFirstChild("HumanoidRootPart") then
        return "Idle"
    end

    local dist = (char.HumanoidRootPart.Position - spawn.Position).Magnitude

    if dist < 80 then
        if #EnemyFolder:GetChildren() > 0 then
            return "InRaid"
        else
            return "Waiting"
        end
    end

    return "Idle"
end

--// UPDATE STATE
task.spawn(function()
    while task.wait(1) do
        local new = GetState()

        if new == "InRaid" and raidState ~= "InRaid" then
            raidStartTime = tick()
        end

        raidState = new
    end
end)

--// AUTO RAID LOOP
task.spawn(function()
    while task.wait(2) do
        if AutoRaid then

            if raidState == "InRaid" then
                local passed = tick() - raidStartTime
                if passed >= RAID_DURATION then
                    raidState = "Idle"
                    task.wait(2)
                end
            end

            if raidState == "Idle" then
                if NPC then
                    TP_RAID(NPC.CFrame + Vector3.new(0,3,0))
                    task.wait(1)

                    CreateRaid()
                    task.wait(1)

                    StartRaid()
                    task.wait(2)

                    local spawn = GetSpawn()
                    if spawn then
                        TP_RAID(spawn.CFrame + Vector3.new(0,5,0))
                    end

                    task.wait(12)
                end
            end
        end
    end
end)

--// GET NEAREST
local function GetNearest()
    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local nearest, dist = nil, math.huge

    for _,mob in pairs(EnemyFolder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - root.Position).Magnitude
            if d < dist then
                dist = d
                nearest = hrp
            end
        end
    end

    return nearest
end

--// TP LOOP (SMOOTH, GA GOYANG)
task.spawn(function()
    while task.wait(0.2) do
        if TP and raidState == "InRaid" then
            local t = GetNearest()
            if t and tick() - lastTP > 0.25 then
                lastTP = tick()

                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = root.CFrame:Lerp(t.CFrame * CFrame.new(0,0,4), 0.4)
                end
            end
        end
    end
end)

--// AURA LOOP (MAX SPEED)
task.spawn(function()
