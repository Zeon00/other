--// ENEMY
local EnemyFolder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")

--// NPC + RAID
local NPC = workspace._MAP["Easter 2026 Event"].Interactions.Gamemode.EasterLevi.HumanoidRootPart
local RaidMap = workspace._MAP.Gamemode["Easter Raid_8594485805"]
local SpawnPart = RaidMap.Spawn

--// SETTINGS AURA
local Aura, TP, Skill = false, false, false
local TPMode = "Nearest"
local SelectedMobs = {}

local lastSkill = 0
local skillDelay = 2
local lastTP = 0

--// SETTINGS RAID
local AutoRaid = false
local RAID_DURATION = 900
local raidState = "Idle"
local raidStartTime = 0

--// ================= AURA SYSTEM =================

local function GetMobName(mob)
    return mob:GetAttribute("Name") or mob.Name
end

local function GetTarget()
    for _,mob in pairs(EnemyFolder:GetChildren()) do
        if SelectedMobs[GetMobName(mob)] then
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            if hrp then return hrp end
        end
    end
end

local function GetNearest()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local root = char.HumanoidRootPart
    local nearest, dist = nil, math.huge

    for _,mob in pairs(EnemyFolder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - root.Position).Magnitude
            if d < dist then
                dist = d
                nearest = hrp
            end
        end
    end

    return nearest
end

local function TPTo(hrp)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local root = char.HumanoidRootPart
    local dist = (hrp.Position - root.Position).Magnitude

    if dist < 6 then return end
    if tick() - lastTP < 0.25 then return end
    lastTP = tick()

    root.CFrame = root.CFrame:Lerp(hrp.CFrame * CFrame.new(0,0,4), 0.5)
end

task.spawn(function()
    while task.wait(0.25) do
        if TP then
            local target = (TPMode == "Selected") and GetTarget() or GetNearest()
            if target then TPTo(target) end
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Aura then
            pcall(function()
                Remote:Fire("ClickSystem","Execute",Library.Target)
            end)

            if Skill and tick() - lastSkill > skillDelay then
                lastSkill = tick()
                pcall(function()
                    ScrollRemote:FireServer({
                        {
                            "PetSystem","Open","Easter 2026 Scroll","One",n = 4
                        },"\002"
                    })
                end)
            end

            local atkspd = 1
            pcall(function()
                atkspd = MultiplierService:AtkSPD(player)
            end)

            atkspd = (atkspd and atkspd > 0) and atkspd or 1
            atkspd = atkspd * 1.5

            pcall(function()
                local char = player.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.WalkSpeed = 24
                end
            end)

            task.wait(math.max(0.03, 0.6 / atkspd))
        end
    end
end)

--// ================= RAID SYSTEM =================

local function TP_RAID(cf)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = cf
    end
end

local function CreateRaid()
    RemoteEvent:FireServer({{"GamemodeSystem","Create","Easter Raid","ChocolateKingdom","Easy",true,n=6},"\002"})
end

local function StartRaid()
    RemoteEvent:FireServer({{"GamemodeSystem","Start","Easter Raid",8594485805,n=4},"\002"})
end

local function GetState()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return "Idle" end

    local dist = (char.HumanoidRootPart.Position - SpawnPart.Position).Magnitude

    if dist < 80 then
        if #EnemyFolder:GetChildren() > 0 then
            return "InRaid"
        else
            return "Waiting"
        end
    end

    return "Idle"
end

task.spawn(function()
    while task.wait(1) do
        local new = GetState()
        if new == "InRaid" and raidState ~= "InRaid" then
            raidStartTime = tick()
        end
        raidState = new
    end
end)

task.spawn(function()
    while task.wait(2) do
        if AutoRaid then

            if raidState == "InRaid" then
                local passed = tick() - raidStartTime
                if passed >= RAID_DURATION or #EnemyFolder:GetChildren() == 0 then
                    raidState = "Idle"
                    task.wait(2)
                end
            end

            if raidState == "Idle" then
                TP_RAID(NPC.CFrame + Vector3.new(0,3,0))
                task.wait(1)

                CreateRaid()
                task.wait(1)

                StartRaid()
                task.wait(2)

                TP_RAID(SpawnPart.CFrame + Vector3.new(0,5,0))
                task.wait(12)
            end
        end
    end
end)

