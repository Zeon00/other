-- SCROLL
local scroll=Instance.new("ScrollingFrame",main)
scroll.Size=UDim2.new(1,-10,1,-230)
scroll.Position=UDim2.new(0,5,0,220)
scroll.BackgroundTransparency=1

local layout=Instance.new("UIListLayout",scroll)
layout.Padding=UDim.new(0,5)

local buttons={}
local allState=false

local function CreateMob(name)
    if buttons[name] then return end

    local btn=Instance.new("TextButton",scroll)
    btn.Size=UDim2.new(1,-5,0,25)
    btn.BackgroundColor3=Color3.fromRGB(40,40,40)

    local state=false
    btn.Text="[ ] "..name

    btn.MouseButton1Click:Connect(function()
        SelectedMobs[name]=not SelectedMobs[name]
        local s=SelectedMobs[name]
        btn.Text=(s and "[✔] " or "[ ] ")..name
    end)

    buttons[name]=btn
end

local function Refresh()
    for _,m in pairs(EnemyFolder:GetChildren()) do
        CreateMob(GetMobName(m))
    end
    scroll.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+10)
end

Refresh()
EnemyFolder.ChildAdded:Connect(Refresh)
EnemyFolder.ChildRemoved:Connect(Refresh)

all.MouseButton1Click:Connect(function()
    allState=not allState
    for name,btn in pairs(buttons) do
        SelectedMobs[name]=allState
        btn.Text=(allState and "[✔] " or "[ ] ")..name
    end
    all.Text=allState and "Unselect All" or "Select All"
end)
