--// SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

--// LIB
local Library = require(RS:WaitForChild("Framework"):WaitForChild("Library"))
local Remote = Library.Remote
local MultiplierService = Library:GetService("MultiplierService")

--// REMOTE
local RemoteEvent = RS:WaitForChild("ffrostflame_bridgenet2@1.0.0"):WaitForChild("dataRemoteEvent")

--// ENEMY
local EnemyFolder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")

----------------------------------------------------------------
-- 🔥 FARM SYSTEM
----------------------------------------------------------------
local Aura, TP = false, false
local TPMode = "Nearest"
local SelectedMobs = {}
local lastTP = 0

local function GetMobName(m)
    return m:GetAttribute("Name") or m.Name
end

local function GetTarget()
    for _,m in pairs(EnemyFolder:GetChildren()) do
        if SelectedMobs[GetMobName(m)] then
            return m:FindFirstChild("HumanoidRootPart")
        end
    end
end

local function GetNearest()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart

    local near,dist=nil,math.huge
    for _,m in pairs(EnemyFolder:GetChildren()) do
        local hrp = m:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d=(hrp.Position-root.Position).Magnitude
            if d<dist then dist=d near=hrp end
        end
    end
    return near
end

task.spawn(function()
    while task.wait(0.2) do
        if TP then
            local t = (TPMode=="Selected") and GetTarget() or GetNearest()
            if t and tick()-lastTP>0.25 then
                lastTP=tick()
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = root.CFrame:Lerp(t.CFrame*CFrame.new(0,0,4),0.4)
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Aura then
            pcall(function()
                Remote:Fire("ClickSystem","Execute",Library.Target)
            end)

            local atk=1
            pcall(function() atk=MultiplierService:AtkSPD(player) end)
            atk=(atk>0 and atk or 1)*1.5

            task.wait(math.max(0.03,0.6/atk))
        end
    end
end)

----------------------------------------------------------------
-- 🔥 RAID SYSTEM
----------------------------------------------------------------
local AutoRaid, RaidAura, RaidTP = false,false,false
local RAID_DURATION = 900

local raidState="Idle"
local raidStart=0

-- NPC SAFE
local NPC
task.spawn(function()
    repeat task.wait() until workspace:FindFirstChild("_MAP")
    repeat task.wait() until workspace._MAP:FindFirstChild("Easter 2026 Event")
    repeat task.wait() until workspace._MAP["Easter 2026 Event"].Interactions.Gamemode:FindFirstChild("EasterLevi")
    NPC = workspace._MAP["Easter 2026 Event"].Interactions.Gamemode.EasterLevi.HumanoidRootPart
end)

-- SPAWN SAFE
local function GetSpawn()
    local m=workspace:FindFirstChild("_MAP")
    if not m then return end
    local g=m:FindFirstChild("Gamemode")
    if not g then return end
    local r=g:FindFirstChild("Easter Raid_8594485805")
    return r and r:FindFirstChild("Spawn")
end

local function TP_RAID(cf)
    local c=player.Character
    if c and c:FindFirstChild("HumanoidRootPart") then
        c.HumanoidRootPart.CFrame=cf
    end
end

local function CreateRaid()
    RemoteEvent:FireServer({{"GamemodeSystem","Create","Easter Raid","ChocolateKingdom","Easy",true,n=6},"\002"})
end

local function StartRaid()
    RemoteEvent:FireServer({{"GamemodeSystem","Start","Easter Raid",8594485805,n=4},"\002"})
end

local function GetState()
    local sp=GetSpawn()
    local c=player.Character
    if not sp or not c or not c:FindFirstChild("HumanoidRootPart") then return "Idle" end

    local d=(c.HumanoidRootPart.Position-sp.Position).Magnitude
    if d<80 then
        if #EnemyFolder:GetChildren()>0 then return "InRaid" else return "Waiting" end
    end
    return "Idle"
end

task.spawn(function()
    while task.wait(1) do
        local s=GetState()
        if s=="InRaid" and raidState~="InRaid" then raidStart=tick() end
        raidState=s
    end
end)

task.spawn(function()
    while task.wait(2) do
        if AutoRaid then
            if raidState=="InRaid" then
                if tick()-raidStart>=RAID_DURATION then raidState="Idle" end
            end

            if raidState=="Idle" and NPC then
                TP_RAID(NPC.CFrame+Vector3.new(0,3,0))
                task.wait(1)
                CreateRaid()
                task.wait(1)
                StartRaid()
                task.wait(2)

                local sp=GetSpawn()
                if sp then TP_RAID(sp.CFrame+Vector3.new(0,5,0)) end
                task.wait(12)
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.03) do
        if RaidAura and raidState=="InRaid" then
            pcall(function()
                Remote:Fire("ClickSystem","Execute",Library.Target)
            end)
        end
    end
end)

task.spawn(function()
    while task.wait(0.2) do
        if RaidTP and raidState=="InRaid" then
            local t=GetNearest()
            local root=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if t and root then
                root.CFrame=root.CFrame:Lerp(t.CFrame*CFrame.new(0,0,4),0.4)
            end
        end
    end
end)

