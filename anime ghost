local buttons = {}
local allState = false

local function CreateMob(name)
    if buttons[name] then return end

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,-5,0,25)
    btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Parent = scroll
    Instance.new("UICorner", btn)

    local state = SelectedMobs[name] or false
    btn.Text = (state and "[✔] " or "[ ] ")..name

    btn.MouseButton1Click:Connect(function()
        SelectedMobs[name] = not SelectedMobs[name]
        local s = SelectedMobs[name]
        btn.Text = (s and "[✔] " or "[ ] ")..name
    end)

    buttons[name] = btn
end

local function Refresh()
    for _,mob in pairs(EnemyFolder:GetChildren()) do
        CreateMob(GetMobName(mob))
    end
    scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 10)
end

Refresh()
EnemyFolder.ChildAdded:Connect(Refresh)
EnemyFolder.ChildRemoved:Connect(Refresh)

allBtn.MouseButton1Click:Connect(function()
    allState = not allState
    for name,btn in pairs(buttons) do
        SelectedMobs[name] = allState
        btn.Text = (allState and "[✔] " or "[ ] ")..name
    end
    allBtn.Text = allState and "Unselect All" or "Select All"
end)





