local scroll = Instance.new("ScrollingFrame", main)
scroll.Size = UDim2.new(1,-10,1,-210)
scroll.Position = UDim2.new(0,5,0,320)
scroll.BackgroundTransparency = 1
scroll.CanvasSize = UDim2.new(0,0,0,0)
scroll.ScrollBarThickness = 6
local layout = Instance.new("UIListLayout", scroll)
layout.Padding = UDim.new(0,5)

local added = {}

local function RefreshList()
    for _,v in pairs(scroll:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    table.clear(added)

    for _,mob in pairs(EnemyFolder:GetChildren()) do
        local name = GetMobName(mob)

        if not added[name] then
            added[name] = true

            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,-5,0,25)
            btn.Text = "[ ] "..name
            btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Parent = scroll
            Instance.new("UICorner", btn)

            btn.MouseButton1Click:Connect(function()
                SelectedMobs[name] = not SelectedMobs[name]
                btn.Text = (SelectedMobs[name] and "[✔] " or "[ ] ")..name
            end)
        end
    end

    scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 10)
end

-- AUTO REFRESH LIST
RefreshList()
EnemyFolder.ChildAdded:Connect(RefreshList)
