-- FUNCTION
local function getHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getNearestMob()
    local hrp = getHRP()
    if not hrp then return end

    local closest, dist = nil, math.huge

    for _, mob in pairs(workspace:WaitForChild("Mobs"):GetChildren()) do
        local mHRP = mob:FindFirstChild("HumanoidRootPart")
        if mHRP then
            local d = (mHRP.Position - hrp.Position).Magnitude
            if d < dist then
                dist = d
                closest = mob
            end
        end
    end

    return closest
end

-- MAIN LOOP
RunService.RenderStepped:Connect(function()
    local hrp = getHRP()
    if not hrp then return end

    if not currentTarget or not currentTarget.Parent then
        currentTarget = getNearestMob()
        lastSwitch = tick()
    end

    if tick() - lastSwitch > SWITCH_DELAY then
        currentTarget = getNearestMob()
        lastSwitch = tick()
    end

    local mob = currentTarget
    if not mob then return end

    local mHRP = mob:FindFirstChild("HumanoidRootPart")
    if not mHRP then return end

    if AutoTP then
        hrp.CFrame = mHRP.CFrame * CFrame.new(0,0,-3)
    end

    if KillAura then
        pcall(function()
            ClickRemote:InvokeServer(mob.Name)
        end)
    end
end)

