-- FUNCTION
local function getTargetPlayer()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Name:lower():find(TargetPlayerName:lower()) then
            return plr
        end
    end
end
local function getHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getNearestMob()
    local hrp = getHRP()
    if not hrp then return end

    local closest, dist = nil, math.huge

    for _, mob in pairs(workspace:WaitForChild("Mobs"):GetChildren()) do
        local mHRP = mob:FindFirstChild("HumanoidRootPart")
        if mHRP then
            local d = (mHRP.Position - hrp.Position).Magnitude
            if d < dist and d > 2 then
                dist = d
                closest = mob
            end
        end
    end

    return closest
end

-- MAIN LOOP
RunService.RenderStepped:Connect(function()
    local hrp = getHRP()
    if not hrp then return end

    -- AUTO FOLLOW PRIORITAS
    if AutoFollow then
        local target = getTargetPlayer()
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local targetHRP = target.Character.HumanoidRootPart
            
            -- smooth biar ga geter
            hrp.CFrame = hrp.CFrame:Lerp(targetHRP.CFrame * CFrame.new(0,0,-3), 0.2)
        end
        return -- stop logic lain biar ga tabrakan
    end

    -- ==== LOGIC LAMA ====
    if not currentTarget or not currentTarget.Parent then
        currentTarget = getNearestMob()
        lastSwitch = tick()
    end

    if tick() - lastSwitch > SWITCH_DELAY then
        currentTarget = getNearestMob()
        lastSwitch = tick()
    end

    local mob = currentTarget
    if not mob then return end

    local mHRP = mob:FindFirstChild("HumanoidRootPart")
    if not mHRP then return end

    if AutoTP or TPNearest then
        hrp.CFrame = mHRP.CFrame * CFrame.new(0,0,-3)
    end

    if KillAura then
        pcall(function()
            ClickRemote:InvokeServer(mob.Name)
        end)
    end
end)

