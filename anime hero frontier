-- GET NEAREST ENEMY
local function GetNearestEnemy()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")

    if not hrp then
        return nil
    end

    local closest
    local distance = math.huge

    local enemiesFolder = workspace:FindFirstChild("Enemies")
    and workspace.Enemies:FindFirstChild("Character")

    if not enemiesFolder then
        return nil
    end

    for _, enemy in pairs(enemiesFolder:GetChildren()) do
        local enemyHRP = enemy:FindFirstChild("HumanoidRootPart")
        local humanoid = enemy:FindFirstChildOfClass("Humanoid")

        if enemyHRP and humanoid and humanoid.Health > 0 then
            local mag = (hrp.Position - enemyHRP.Position).Magnitude

            if mag < distance then
                distance = mag
                closest = enemy
            end
        end
    end

    return closest
end

-- FARM LOOP
task.spawn(function()
    while task.wait() do
        if AutoFarm then
            pcall(function()
                local enemy = GetNearestEnemy()

                if enemy then
                    local hrp = player.Character.HumanoidRootPart
                    local enemyHRP = enemy.HumanoidRootPart

                    hrp.CFrame = enemyHRP.CFrame * CFrame.new(0,0,3)

                    ClickRemote:FireServer()

                    Status.Text = "Target : "..enemy.Name
                else
                    Status.Text = "No Enemy"
                end
            end)
        else
            Status.Text = "Idle"
        end
    end
end)
