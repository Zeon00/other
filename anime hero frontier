-- AUTO TP LOOP
task.spawn(function()
    while task.wait(0.1) do
        if AutoTP then
            pcall(function()
                local enemy = GetNearestEnemy()

                if enemy then
                    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    local enemyHRP = enemy:FindFirstChild("HumanoidRootPart")

                    if hrp and enemyHRP then
                        hrp.CFrame = enemyHRP.CFrame * CFrame.new(0,0,3)
                        Status.Text = "TP To : "..enemy.Name
                    end
                else
                    Status.Text = "No Enemy"
                end
            end)
        end
    end
end)

-- AUTO WALK LOOP
task.spawn(function()
    while task.wait(0.1) do
        if AutoWalk then
            pcall(function()
                local enemy = GetNearestEnemy()

                if enemy then
                    local character = player.Character
                    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                    local enemyHRP = enemy:FindFirstChild("HumanoidRootPart")

                    if humanoid and enemyHRP then
                        humanoid:MoveTo(enemyHRP.Position)
                        Status.Text = "Walking To : "..enemy.Name
                    end
                else
                    Status.Text = "No Enemy"
                end
            end)
        end
    end
end)
