-- TOGGLE AURA
aura.MouseButton1Click:Connect(function()

    _G.FighterAura = not _G.FighterAura

    if _G.FighterAura then

        aura.Text = "Aura : ON"

        TweenService:Create(aura,TweenInfo.new(0.2),{
            BackgroundColor3 = Color3.fromRGB(0,255,120)
        }):Play()

    else

        aura.Text = "Aura : OFF"

        TweenService:Create(aura,TweenInfo.new(0.2),{
            BackgroundColor3 = Color3.fromRGB(40,40,40)
        }):Play()
    end
end)

