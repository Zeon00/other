-- AUTO TP LOOP
task.spawn(function()

    while task.wait(0.15) do

        if _G.AutoTP or _G.TPNearest then

            local char = player.Character

            if char and char:FindFirstChild("HumanoidRootPart") then

                local hrp = char.HumanoidRootPart

                local nearest = nil
                local shortest = math.huge

                local blacklist = {
                    ["Dummy"] = true,
                    ["Training Dummy"] = true,
                    ["Damage Dummy"] = true
                }

                for _,enemy in pairs(workspace.Client.Enemies:GetChildren()) do

                    if not blacklist[enemy.Name] then

                        local humanoid = enemy:FindFirstChildOfClass("Humanoid")
                        local enemyHRP = enemy:FindFirstChild("HumanoidRootPart")

                        if humanoid
                        and humanoid.Health > 0
                        and enemyHRP
                        and enemyHRP:IsDescendantOf(workspace)
                        and enemyHRP.Position.Y > -50 then

                            local dist = (enemyHRP.Position - hrp.Position).Magnitude

                            -- TP NEAREST
                            if _G.TPNearest then

                                if dist < shortest then
                                    shortest = dist
                                    nearest = enemyHRP
                                end

                            -- AUTO TP SELECTED
                            else

                                if SelectedMobs[enemy.Name] then
                                    hrp.CFrame = enemyHRP.CFrame * CFrame.new(0,0,5)
                                    break
                                end
                            end
                        end
                    end
                end

                if _G.TPNearest and nearest then
                    hrp.CFrame = nearest.CFrame * CFrame.new(0,0,5)
                end
            end
        end
    end
end)

