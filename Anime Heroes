-- FUNCTIONS

local function GetFighters()
    local folder = workspace.Server.Fighters:FindFirstChild(tostring(player.UserId))
    if not folder then return {} end

    local t = {}

    for _,v in pairs(folder:GetChildren()) do
        if v:FindFirstChild("Target") then
            table.insert(t,v)
        end
    end

    return t
end

local function GetMobs()
    local t = {}

    local char = player.Character
    if not char then return t end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return t end

    for _,mob in pairs(workspace.Server.Enemies:GetDescendants()) do
        if mob:IsA("BasePart")
        and mob:GetAttribute("ID")
        and not mob:GetAttribute("Died") then

            if (mob.Position - hrp.Position).Magnitude <= 70 then
                table.insert(t,mob)
            end
        end
    end

    return t
end

-- AURA LOOP
task.spawn(function()
    while task.wait(0.03) do

        if _G.FighterAura then

            local fighters = GetFighters()
            local mobs = GetMobs()

            if #fighters > 0 and #mobs > 0 then

                for i,fighter in pairs(fighters) do

                    local mob = mobs[(i % #mobs) + 1]

                    if mob then

                        Bridge:FireServer(
                            "Fighters",
                            "Attack",
                            "Attack",
                            mob:GetAttribute("Class"),
                            mob,
                            fighter.Name
                        )

                        Bridge:FireServer(
                            "Fighters",
                            "Attack",
                            "Do_Damage",
                            fighter.Name
                        )
                    end
                end
            end
        end
    end
end)

