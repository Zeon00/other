        selectall.BackgroundColor3 = Color3.fromRGB(0,255,120)

        for _,enemy in pairs(workspace.Client.Enemies:GetChildren()) do

            local blacklist = {
                ["Dummy"] = true,
                ["Training Dummy"] = true,
                ["Damage Dummy"] = true
            }

            if not blacklist[enemy.Name] then
                SelectedMobs[enemy.Name] = true
            end
        end

    else

        selectall.Text = "Select All Mobs : OFF"
        selectall.BackgroundColor3 = Color3.fromRGB(40,40,40)

        for mobName,_ in pairs(SelectedMobs) do
            SelectedMobs[mobName] = false
        end
    end

    RefreshDropdown()
end)

