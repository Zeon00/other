--// REFRESH MAPS (FIX TOTAL)
local function Refresh()
    for _,v in ipairs(List:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    for _,m in ipairs(Maps) do
        local b = Instance.new("TextButton")
        b.Parent = List
        b.Size = UDim2.new(1,0,0,25)
        b.Text = m
        b.BackgroundColor3 = Color3.fromRGB(70,70,70)
        b.TextColor3 = Color3.new(1,1,1)

        b.MouseButton1Click:Connect(function()
            SelectedMap = m
            MapBtn.Text = "Map: "..m
            List.Visible = false
            List.Size = UDim2.new(0,260,0,0)
        end)
    end
end

Refresh()

--// TOGGLE LIST
MapBtn.MouseButton1Click:Connect(function()
    List.Visible = not List.Visible
    List.Size = List.Visible and UDim2.new(0,260,0,120) or UDim2.new(0,260,0,0)
end)

--// MODE SWITCH
ModeBtn.MouseButton1Click:Connect(function()
    ModeIndex += 1
    if ModeIndex > #ModeOrder then ModeIndex = 1 end

    SelectedMode = ModeOrder[ModeIndex]
    Maps = Modes[SelectedMode]
    SelectedMap = Maps[1]

    ModeBtn.Text = "Mode: "..SelectedMode
    MapBtn.Text = "Map: "..SelectedMap

    Refresh()
end)

--// AUTO LOOP (FIXED STABLE)
task.spawn(function()
    while task.wait(2) do
        if AutoFarm and Running then

            for _,mode in ipairs(ModeOrder) do
                for _,map in ipairs(Modes[mode]) do
                    if not AutoFarm or not Running then return end

                    pcall(function()
                        Remote:FireServer({
                            {{"GamemodeSystem","Create",mode,map,"Easy",n=6}, "\002"}
                        })
                    end)

                    task.wait(1.5)

                    pcall(function()
                        Remote:FireServer({
                            {{"GamemodeSystem","Start",mode,8594485805,n=4}, "\002"}
                        })
                    end)

                    task.wait(7)
                end
            end
        end
    end
end)

