Instance.new("UICorner", List)

local Layout = Instance.new("UIListLayout", List)
Layout.Padding = UDim.new(0,5)

local function LoadMaps()
    for _,v in ipairs(List:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    for _,m in ipairs(Maps) do
        local b = Instance.new("TextButton")
        b.Parent = List
        b.Size = UDim2.new(1,0,0,25)
        b.Text = m
        b.BackgroundColor3 = Color3.fromRGB(70,70,70)
        b.TextColor3 = Color3.new(1,1,1)

        b.MouseButton1Click:Connect(function()
            SelectedMap = m
            MapBtn.Text = m
            List.Visible = false
            List.Size = UDim2.new(1,0,0,0)
        end)
    end
end

LoadMaps()

MapBtn.MouseButton1Click:Connect(function()
    List.Visible = not List.Visible
    List.Size = List.Visible and UDim2.new(1,0,0,120) or UDim2.new(1,0,0,0)
end)

-- MODE ROTATION + AUTO SYSTEM
task.spawn(function()
    while task.wait(2) do

        if not Running then continue end

        for _,mode in ipairs(ModeOrder) do

            if (mode == "Defense Mode" and DefenseON)
            or (mode == "Elemental Mode" and ElementalON) then

                local maps = Modes[mode]

                for _,map in ipairs(maps) do

                    if not Running then return end

                    -- CREATE
                    pcall(function()
                        Remote:FireServer({
                            {{"GamemodeSystem","Create",mode,map,"Easy",n=6}, "\002"}
                        })
                    end)

                    task.wait(1.5)

                    -- START
                    pcall(function()
                        Remote:FireServer({
                            {{"GamemodeSystem","Start",mode,8594485805,n=4}, "\002"}
                        })
                    end)

                    task.wait(6)
                end
            end
        end
    end
end)
