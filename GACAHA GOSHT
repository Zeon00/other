local function UseTickets()
    local args = {
        {
            {
                "ItemSystem",
                "Use",
                "ElementalTickets",
                n = 3
            },
            "\002"
        }
    }

    Remote:FireServer(unpack(args))
end
--// EXACT REMOTE FUNCTION (INI FIX UTAMA)
local function FireCreate(mode, map)
    local args = {
        {
            {
                "GamemodeSystem",
                "Create",
                mode,
                map,
                "Easy",
                n = 6
            },
            "\002"
        }
    }

    Remote:FireServer(unpack(args))
end
local function FireStart(mode)

    CurrentMode = mode

    local args = {
        {
            {
                "GamemodeSystem",
                "Start",
                mode,
                8594485805,
                n = 4
            },
            "\002"
        }
    }

    Remote:FireServer(unpack(args))

    InRaid = true
    RaidStartTime = tick()
end

