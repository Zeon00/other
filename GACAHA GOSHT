-- REFRESH MAPS
local function RefreshMaps()
    for _,v in ipairs(ListFrame:GetChildren()) do
        if v:IsA("TextButton") then
            v:Destroy()
        end
    end

    for _,map in ipairs(Maps) do
        local b = Instance.new("TextButton")
        b.Parent = ListFrame
        b.Size = UDim2.new(1,0,0,30)
        b.Text = map
        b.BackgroundColor3 = Color3.fromRGB(60,60,60)
        b.TextColor3 = Color3.new(1,1,1)

        b.MouseButton1Click:Connect(function()
            SelectedMap = map
            Dropdown.Text = "Map: "..map
            ListFrame.Visible = false
            ListFrame.Size = UDim2.new(0,260,0,0)
        end)
    end
end

RefreshMaps()

-- TOGGLE AUTO
local Toggle = Instance.new("TextButton")
Toggle.Parent = Main
Toggle.Size = UDim2.new(0,260,0,30)
Toggle.Position = UDim2.new(0,20,0,200)
Toggle.Text = "AUTO: OFF"
Toggle.BackgroundColor3 = Color3.fromRGB(170,50,50)
Toggle.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", Toggle)

Toggle.MouseButton1Click:Connect(function()
    AutoFarm = not AutoFarm
    Toggle.Text = AutoFarm and "AUTO: ON" or "AUTO: OFF"
    Toggle.BackgroundColor3 = AutoFarm and Color3.fromRGB(50,170,50) or Color3.fromRGB(170,50,50)
end)

-- MODE SWITCH
ModeBtn.MouseButton1Click:Connect(function()
    SelectedModeIndex += 1
    if SelectedModeIndex > #ModeOrder then
        SelectedModeIndex = 1
    end

    SelectedMode = ModeOrder[SelectedModeIndex]
    Maps = Modes[SelectedMode]
    SelectedMap = Maps[1]

    ModeBtn.Text = "Mode: "..SelectedMode
    Dropdown.Text = "Map: "..SelectedMap

    RefreshMaps()
end)

-- DROPDOWN
Dropdown.MouseButton1Click:Connect(function()
    ListFrame.Visible = not ListFrame.Visible
    ListFrame.Size = ListFrame.Visible and UDim2.new(0,260,0,120) or UDim2.new(0,260,0,0)
end)

-- AUTO SEQUENCE SYSTEM
task.spawn(function()
    while task.wait(2) do
        if AutoFarm then

            -- LOOP MODE ORDER: Defense → Elemental
            for _,mode in ipairs(ModeOrder) do

                local maps = Modes[mode]

                for _,map in ipairs(maps) do

                    if not AutoFarm then return end

                    -- CREATE
                    local createArgs = {
                        {
                            {"GamemodeSystem","Create",mode,map,"Easy", n = 6},
                            "\002"
                        }
                    }

                    pcall(function()
                        Remote:FireServer(unpack(createArgs))
                    end)

                    task.wait(1.5)

                    -- START
                    local startArgs = {
                        {
                            {"GamemodeSystem","Start",mode,8594485805, n = 4},
                            "\002"
                        }
                    }

                    pcall(function()
                        Remote:FireServer(unpack(startArgs))
                    end)

                    task.wait(8) -- ⬅️ timing biar game sempet jalan
                end
            end
        end
    end
end)
