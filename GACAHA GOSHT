--// SPIN FUNCTION
local function doSpin(name, mode, data)
    local args = {
        {
            {
                "GachaSystem",
                "Spin",
                name,
                mode,
                data,
                n = 5
            },
            "\002"
        }
    }

    remote:FireServer(unpack(args))
end

