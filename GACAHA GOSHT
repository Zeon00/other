local RS = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local Remote = RS:WaitForChild("ffrostflame_bridgenet2@1.0.0"):WaitForChild("dataRemoteEvent")

--// STATE
local DefenseON = false
local ElementalON = false
local Running = true
local LightningON = false
local RaidStartTime = 0
local AutoTeleportDelay = 120 -- 2 menit
local InRaid = false
