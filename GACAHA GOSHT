--// CLEAN GUI
pcall(function()
    local g = game.CoreGui:FindFirstChild("DefenseFarmGUI")
    if g then g:Destroy() end
end)

local RS = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")
local Remote = RS:WaitForChild("ffrostflame_bridgenet2@1.0.0"):WaitForChild("dataRemoteEvent")

--// DATA
local Modes = {
    Defense = {"SinVillage","DestroyedVillage","CursedZone","BizarreDesert"},
    Elemental = {"FireRaid","WaterRaid","WindRaid"}
}

local Selected = {
    DefenseMap = Modes.Defense[1],
    ElementalMap = Modes.Elemental[1]
}

local DefenseON = false
local ElementalON = false
local Running = true

--// GUI
local Gui = Instance.new("ScreenGui")
Gui.Name = "DefenseFarmGUI"
Gui.Parent = game.CoreGui
Gui.ResetOnSpawn = false

local Main = Instance.new("Frame")
Main.Size = UDim2.new(0, 320, 0, 260)
Main.Position = UDim2.new(0.5,-160,0.5,-130)
Main.BackgroundColor3 = Color3.fromRGB(25,25,25)
Main.Parent = Gui
Instance.new("UICorner", Main)

--// DRAG
local UIS2 = game:GetService("UserInputService")
local drag, start, pos

Main.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true
        start = i.Position
        pos = Main.Position
        i.Changed:Connect(function()
            if i.UserInputState == Enum.UserInputState.End then
                drag = false
            end
        end)
    end
end)

UIS2.InputChanged:Connect(function(i)
    if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
        local d = i.Position - start
        Main.Position = UDim2.new(pos.X.Scale,pos.X.Offset+d.X,pos.Y.Scale,pos.Y.Offset+d.Y)
    end
end)

--// TITLE
local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1,0,0,30)
Title.Text = "AUTO FARM SEPARATE MODE"
Title.TextColor3 = Color3.new(1,1,1)
Title.BackgroundTransparency = 1
Title.Parent = Main

--// CLOSE
local Close = Instance.new("TextButton")
Close.Size = UDim2.new(0,25,0,25)
Close.Position = UDim2.new(1,-30,0,3)
Close.Text = "X"
Close.BackgroundColor3 = Color3.fromRGB(200,50,50)
Close.Parent = Main
Instance.new("UICorner", Close)

Close.MouseButton1Click:Connect(function()
    Running = false
    Gui:Destroy()
end)

--// DEFENSE TOGGLE
local Def = Instance.new("TextButton")
Def.Size = UDim2.new(0,140,0,35)
