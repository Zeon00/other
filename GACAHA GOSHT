--// LOOP DEFENSE (SENDIRIAN)
task.spawn(function()
    while task.wait(2) do
        if DefenseON and Running then
            for _,map in ipairs(Modes.Defense) do
                if not DefenseON then break end

                pcall(function()
                    Remote:FireServer({
                        {{"GamemodeSystem","Create","Defense Mode",map,"Easy",n=6}, "\002"}
                    })
                end)

                task.wait(1.5)

                pcall(function()
                    Remote:FireServer({
                        {{"GamemodeSystem","Start","Defense Mode",8594485805,n=4}, "\002"}
                    })
                end)

                task.wait(7)
            end
        end
    end
end)

