--// AUTO DETECT MOB
local function getMobs()
    local folder = Workspace.Server.Enemies.World:FindFirstChild("Fruits Verse")
    if not folder then return {} end

    local world = folder:FindFirstChild("1")
    if not world then return {} end

    local targets = {}

    for _, mob in pairs(world:GetChildren()) do
        if mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
            targets[mob.Name] = true
        end
    end

    return targets
end

--// REMOTES
local function attack()
    local args = {
        {
            {
                "General",
                "Attack",
                "Click",
                getMobs(),
                n = 4
            },
            "\2"
        }
    }
    Remote:FireServer(unpack(args))
end

local function energy()
    local args = {
        {
            {
                "General",
                "Attack",
                "Click",
                {},
                n = 4
            },
            "\2"
        }
    }
    Remote:FireServer(unpack(args))
end

--// LOOP SUPER FAST
RunService.Heartbeat:Connect(function()
    if AutoAttack then
        attack()
    end
    if AutoEnergy then
        energy()
    end
end)

--// TOGGLES
attackBtn.MouseButton1Click:Connect(function()
    AutoAttack = not AutoAttack
    attackBtn.Text = "Attack "..(AutoAttack and "ON" or "OFF")
    attackBtn.BackgroundColor3 = AutoAttack and Color3.fromRGB(0,170,0) or Color3.fromRGB(50,50,50)
end)

energyBtn.MouseButton1Click:Connect(function()
    AutoEnergy = not AutoEnergy
    energyBtn.Text = "Energy "..(AutoEnergy and "ON" or "OFF")
    energyBtn.BackgroundColor3 = AutoEnergy and Color3.fromRGB(0,170,0) or Color3.fromRGB(50,50,50)
end)

