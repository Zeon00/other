--// CLEAN
pcall(function()
    game.CoreGui.FruitFarmGUI:Destroy()
end)

--// SERVICES
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

--// OMNI
local Omni = require(RS:WaitForChild("Omni"))

--// STATE
local AutoAttack = false
local AutoEnergy = false

--// GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "FruitFarmGUI"

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 240, 0, 160)
main.Position = UDim2.new(0.5, -120, 0.5, -80)
main.BackgroundColor3 = Color3.fromRGB(25,25,25)
main.Active = true
main.Draggable = true
Instance.new("UICorner", main)

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "⚡ Fruit Farm (Smart)"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold

local function makeBtn(name, y)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(0.8,0,0,35)
    b.Position = UDim2.new(0.1,0,y,0)
    b.Text = name.." OFF"
    b.BackgroundColor3 = Color3.fromRGB(50,50,50)
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b)
    return b
end

local atkBtn = makeBtn("Attack",0.3)
local engBtn = makeBtn("Energy",0.6)

-- close
local close = Instance.new("TextButton", main)
close.Size = UDim2.new(0,30,0,30)
close.Position = UDim2.new(1,-35,0,0)
close.Text = "X"
close.BackgroundColor3 = Color3.fromRGB(200,50,50)
Instance.new("UICorner", close)

-- minimize
local mini = Instance.new("TextButton", main)
mini.Size = UDim2.new(0,30,0,30)
mini.Position = UDim2.new(1,-70,0,0)
mini.Text = "-"
mini.BackgroundColor3 = Color3.fromRGB(80,80,80)
Instance.new("UICorner", mini)

local icon = Instance.new("TextButton", gui)
icon.Size = UDim2.new(0,50,0,50)
icon.Position = UDim2.new(0,20,0.5,0)
icon.Text = "⚡"
icon.Visible = false
icon.BackgroundColor3 = Color3.fromRGB(30,30,30)
Instance.new("UICorner", icon)

--// FUNCTIONS
local function attack()
    local mobs = Omni.Cache:Get({"EnemiesOnRangeIds"}) or {}
    Omni.Signal:Fire("General","Attack","Click",mobs)
end

local function energy()
    Omni.Signal:Fire("General","Attack","Click",{})
end

--// LOOP (SMART SPEED)
task.spawn(function()
    while true do
        if AutoAttack then
            attack()
        end
        if AutoEnergy then
            energy()
        end
        task.wait(0.03) -- aman (ikut sistem game)
    end
end)

--// TOGGLE
atkBtn.MouseButton1Click:Connect(function()
    AutoAttack = not AutoAttack
    atkBtn.Text = "Attack "..(AutoAttack and "ON" or "OFF")
    atkBtn.BackgroundColor3 = AutoAttack and Color3.fromRGB(0,170,0) or Color3.fromRGB(50,50,50)
end)

engBtn.MouseButton1Click:Connect(function()
    AutoEnergy = not AutoEnergy
    engBtn.Text = "Energy "..(AutoEnergy and "ON" or "OFF")
    engBtn.BackgroundColor3 = AutoEnergy and Color3.fromRGB(0,170,0) or Color3.fromRGB(50,50,50)
end)

-- close
close.MouseButton1Click:Connect(function()
    gui:Destroy()
end)

-- minimize
mini.MouseButton1Click:Connect(function()
    main.Visible = false
    icon.Visible = true
end)

icon.MouseButton1Click:Connect(function()
    main.Visible = true
    icon.Visible = false
end)
