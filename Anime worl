--------------------------------------------------
-- REFRESH LIST (REAL FROM WORKSPACE)
--------------------------------------------------

local function RefreshMobList()
    list:ClearAllChildren()
    layout.Parent = list

    local folder = workspace:WaitForChild("Client"):WaitForChild("Enemies")
    local mobs = {}

    for _, mob in pairs(folder:GetChildren()) do
        if mob:FindFirstChild("HumanoidRootPart") then
            mobs[mob.Name] = true
        end
    end

    for name in pairs(mobs) do
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, -5, 0, 30)
        b.Text = name
        b.BackgroundColor3 = Color3.fromRGB(50,50,50)
        b.Parent = list

        b.MouseButton1Click:Connect(function()
            SelectedMob = name
            dropTitle.Text = "Mob: "..name
        end)
    end

    list.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y)
end

-- AUTO UPDATE LIST
task.spawn(function()
    while task.wait(2) do
        pcall(RefreshMobList)
    end
end)
