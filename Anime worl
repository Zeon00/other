local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local Omni = require(RS:WaitForChild("Omni"))

-- STATE
local AutoAttack = false
local SelectedMob = nil

--------------------------------------------------
-- GET IDS (FILTER BY SELECTED MOB)
--------------------------------------------------

local function GetIDs()
    local ids = Omni.Cache:Get({"EnemiesOnRangeIds"}) or {}

    if not SelectedMob then
        return ids
    end

    local enemies = Omni.Cache:Get({"Enemies"}) or {}
    local filtered = {}

    for id, _ in pairs(ids) do
        local data = enemies[id]
        if data and data.Model and data.Model.Name == SelectedMob then
            filtered[id] = true
        end
    end

    return filtered
end

--------------------------------------------------
-- FAST HIT LOOP
--------------------------------------------------

task.spawn(function()
    while true do
        if AutoAttack then
            local start = tick()

            local ids = GetIDs()

            if next(ids) then
                for i = 1,3 do
                    Omni.Signal:Fire("General","Attack","Click", ids)
                    task.wait(0.05)
                end
            end

            local cd = Omni.Utils.PlayerStats.ClickCooldown(Omni.Data, Omni.Instance) or 0.2
            local took = tick() - start

            if took < cd then
                task.wait(cd - took)
            else
                task.wait()
            end
        else
            task.wait(0.1)
        end
    end
end)

