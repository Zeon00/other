-- MAIN LOOP (FIX TOTAL)
--------------------------------------------------
local lastTP = 0
local lastTarget = nil
local targetHoldTime = 0

task.spawn(function()
    while true do
        local myhrp = GetHRP()

        if myhrp then

            local target = nil

            -- 🔥 PRIORITAS NEAREST
            if _G.AutoTPNearest then
                target = GetNearestMob(40) or GetNearestMob(200)

            -- 🔥 AUTO TP BIASA
            elseif _G.AutoTP then
                if #mobsCache > 0 then
                    tpIndex = tpIndex % #mobsCache + 1
                    target = mobsCache[tpIndex]
                end
            end

            -- 🔥 VALIDASI TARGET
            if target and target.Parent and IsMobReady(target) then
                local dist = (myhrp.Position - target.Position).Magnitude

                -- 🔥 LOCK TARGET (biar ga pindah2 tiap frame)
                if lastTarget ~= target then
                    lastTarget = target
                    targetHoldTime = tick()
                end

                -- tahan target minimal 0.5 detik
                local holdOK = (tick() - targetHoldTime) > 0.5

                if holdOK then
                    local safe = SafeTP(target.CFrame)

                    -- 🔥 TP DELAY (INI YANG NGURANGIN CEPET)
                    local tpDelay = 0.25

                    if safe and dist > 6 and tick() - lastTP >= tpDelay then
                        myhrp.CFrame = safe
                        lastTP = tick()
                    end
                end
            else
                lastTarget = nil
            end

        end

        task.wait(0.12) -- 🔥 ini juga ngaruh (jangan terlalu kecil)
    end
end)
task.spawn(function()
    while true do
        if _G.AutoAttack then
            local start = tick()
            local ids = GetIDs()

            if next(ids) then
                for i = 1,3 do
                    Omni.Signal:Fire("General","Attack","Click", ids)
                    task.wait(0.03)
                end
            end

            local cd = Omni.Utils.PlayerStats.ClickCooldown(Omni.Data, Omni.Instance) or 0.2
            local took = tick() - start

            if took < cd then
                task.wait(cd - took)
            else
                task.wait()
            end
        else
            task.wait(0.1)
        end
    end
end)

