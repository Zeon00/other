--------------------------------------------------
-- GET HRP
--------------------------------------------------
local function GetHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

--------------------------------------------------
-- GET IDS
--------------------------------------------------
local function GetIDs()
    return Omni.Cache:Get({"EnemiesOnRangeIds"}) or {}
end

local function GetNearestMob(maxDist)
    local myhrp = GetHRP()
    if not myhrp then return end

    local folder = workspace.Client.Enemies
    local closest, dist = nil, maxDist or 50 -- radius

    for _, v in pairs(folder:GetChildren()) do
        local hrp = v:FindFirstChild("HumanoidRootPart")
        local hum = v:FindFirstChildOfClass("Humanoid")

        if hrp and hum and hum.Health > 0 then
            local d = (myhrp.Position - hrp.Position).Magnitude

            if d < dist then
                dist = d
                closest = hrp
            end
        end
    end

    return closest
end
--------------------------------------------------
-- SAFE TELEPORT (ANTI VOID)
--------------------------------------------------
local function SafeTP(cf)
    local origin = cf.Position

    local ray = Ray.new(origin, Vector3.new(0, -100, 0))
    local part, pos = workspace:FindPartOnRay(ray)

    if part and pos then
        return CFrame.new(pos + Vector3.new(0, 3, 0))
    end

    return nil -- skip kalau ga ada tanah
end
--------------------------------------------------
-- VALIDASI MOB (ANTI BUG / BELUM SPAWN)
--------------------------------------------------
local function IsMobReady(hrp)
    if not hrp or not hrp.Parent then return false end

    local hum = hrp.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end

    -- cegah mob bawah map / belum naik
    if hrp.Position.Y < 0 then return false end

    -- cek ada tanah
    local ray = Ray.new(hrp.Position, Vector3.new(0, -50, 0))
    local part = workspace:FindPartOnRay(ray)

    if not part then return false end

    return true
end
