end)

Toggle.MouseButton1Click:Connect(function()
    AutoRaid = not AutoRaid
    Toggle.Text = "Auto Raid: " .. (AutoRaid and "ON" or "OFF")
end)

--// ================= LOGIC =================

local function getRaid()
    return Workspace:FindFirstChild("EasterRaid")
end

local function getEnemies()
    local raid = getRaid()
    if not raid then return {} end
    
    local enemies = {}
    for _, v in pairs(raid:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") then
            if v.Humanoid.Health > 0 then
                table.insert(enemies, v)
            end
        end
    end
    return enemies
end

local function tpToEnemy(enemy)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = enemy.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
    end
end

local function hitEnemy(enemy)
    pcall(function()
        ReplicatedStorage.Remotes.TakeDamage:FireServer(enemy:GetAttribute("UUID") or enemy.Name)
    end)
end

RunService.RenderStepped:Connect(function()
    if not AutoRaid then return end

    local raid = getRaid()

    if not raid then
        pcall(function()
            OpenRaidRemote:FireServer()
        end)
        return
    end

    local enemies = getEnemies()

    if #enemies == 0 then
        return
    end

    local target = enemies[1]
    tpToEnemy(target)
    hitEnemy(target)
end)
