Toggle.MouseButton1Click:Connect(function()
    AutoRaid = not AutoRaid
    Toggle.Text = "Auto Raid: " .. (AutoRaid and "ON" or "OFF")
end)

--// ================= LOGIC =================

local function isRaidActive()
    return Workspace:FindFirstChild("EasterRaid") ~= nil
end

local function getEnemies()
    local raid = Workspace:FindFirstChild("EasterRaid")
    if not raid then return {} end

    local list = {}
    for _, v in pairs(raid:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
            if v.Humanoid.Health > 0 then
                table.insert(list, v)
            end
        end
    end
    return list
end

local function getClosestEnemy(enemies)
    local closest = nil
    local dist = math.huge

    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return nil
    end

    local myPos = player.Character.HumanoidRootPart.Position

    for _, enemy in pairs(enemies) do
        local d = (enemy.HumanoidRootPart.Position - myPos).Magnitude
        if d < dist then
            dist = d
            closest = enemy
        end
    end

    return closest
end

local function tp(enemy)
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = enemy.HumanoidRootPart.CFrame * CFrame.new(0,0,3)
    end
end

local function hit(enemy)
    pcall(function()
        ReplicatedStorage.Remotes.TakeDamage:FireServer(enemy:GetAttribute("UUID") or enemy.Name)
    end)
end

local function openRaid()
    if opening then return end
    opening = true

    print("OPEN RAID...")
    pcall(function()
        OpenRaidRemote:FireServer()
    end)

    task.delay(5, function()
        opening = false
    end)
end

--// MAIN LOOP (STABIL)
task.spawn(function()
    while true do
        task.wait(0.15)

        if not AutoRaid then 
            currentTarget = nil
            continue 
        end

        local raid = Workspace:FindFirstChild("EasterRaid")

        -- ❌ BELUM RAID → OPEN
        if not raid then
            openRaid()
            currentTarget = nil
            continue
        end

        local enemies = getEnemies()

        -- ❌ RAID SELESAI
        if #enemies == 0 then
            currentTarget = nil
            continue
        end

        -- 🎯 LOCK TARGET
        if not currentTarget or currentTarget.Humanoid.Health <= 0 then
            currentTarget = getClosestEnemy(enemies)
        end

        if currentTarget then
            tp(currentTarget)
            hit(currentTarget)
        end
    end
end)
