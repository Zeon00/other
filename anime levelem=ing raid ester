--// ================= LOGIC =================

local function getEnemy()
    local raid = Workspace:FindFirstChild("EasterRaid")
    if not raid then return nil end

    for _, v in pairs(raid:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
            if v.Humanoid.Health > 0 then
                return v
            end
        end
    end
end

local function attack(enemy)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    char.HumanoidRootPart.CFrame = enemy.HumanoidRootPart.CFrame * CFrame.new(0,0,3)

    pcall(function()
        ReplicatedStorage.Remotes.TakeDamage:FireServer(enemy:GetAttribute("UUID") or enemy.Name)
    end)
end

local function openRaid()
    if busyOpening then return end
    busyOpening = true

    pcall(function()
        OpenRaidRemote:FireServer()
    end)

    task.delay(3, function()
        busyOpening = false
    end)
end

-- LOOP
task.spawn(function()
    while true do
        task.wait(0.2)

        if AutoRaid then

            local raid = Workspace:FindFirstChild("EasterRaid")

            if not raid then
                openRaid()
            else
                local enemy = getEnemy()

                if enemy then
                    attack(enemy)
                end
            end

        end
    end
end)


