--// TARGET SYSTEM (FIXED)
local overlap = OverlapParams.new()
overlap.FilterType = Enum.RaycastFilterType.Include
overlap.FilterDescendantsInstances = {
	workspace.Game.Mobs,
	workspace.Game.Rooms,
	workspace.Game.Trials
}

local function getTargets()
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return {} end
	
	local hrp = char.HumanoidRootPart

	local range = 10
	pcall(function()
		range = require(ReplicatedStorage.GameCore).Player.State.Get("Range") or 10
	end)

	local parts = workspace:GetPartBoundsInRadius(hrp.Position, range / 2, overlap)

	local targets = {}
	local used = {}

	for _, part in pairs(parts) do
		local model = part.Parent
		if not used[model] and part:GetAttribute("Enemy") and not part:GetAttribute("Died") then
			table.insert(targets, part)
			used[model] = true
		end
	end

	return targets
end

