--// GET TARGET
local overlap = OverlapParams.new()
overlap.FilterType = Enum.RaycastFilterType.Include
overlap.FilterDescendantsInstances = {
	workspace.Game.Mobs,
	workspace.Game.Rooms,
	workspace.Game.Trials
}

local function getTargets()
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return {} end
	
	local hrp = char.HumanoidRootPart
	local parts = workspace:GetPartBoundsInRadius(hrp.Position, 12, overlap)

	local targets = {}
	local used = {}

	for _, part in pairs(parts) do
		local model = part.Parent
		
		if not used[model] and part:GetAttribute("Enemy") and not part:GetAttribute("Died") then
			table.insert(targets, part)
			used[model] = true
		end
	end

	return targets
end

--// AUTO ATTACK (FAST STABLE)
task.spawn(function()
	while true do
		if AutoAttack then
			local targets = getTargets()

			if #targets > 0 then
				for i = 1, 5 do -- burst
					Remote:FireServer({
						{
							"Action",
							"Action",
							{
								Callback = "M1",
								Action = "Callback",
								Targets = targets
							}
						},
						"\006"
					})

					task.wait(math.random(25,45)/1000) -- anti limit
				end
			end
		end
		
		task.wait(0.05)
	end
end)

