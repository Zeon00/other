--// AUTO TP (SMOOTH)
local mobList = {}
local index = 1
local lastUpdate = 0
local holdTime = 0
local HOLD_DURATION = 2.5 -- lebih cepat pindah

local function updateMobList()
	mobList = {}

	for _, obj in pairs(workspace.Game.Mobs.Client:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name == "HumanoidRootPart" then
			table.insert(mobList, obj)
		end
	end
end

RunService.Heartbeat:Connect(function(dt)
	if AutoTP then
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then return end
		
		local hrp = char.HumanoidRootPart

		lastUpdate = lastUpdate + dt
		if lastUpdate > 1 then
			lastUpdate = 0
			updateMobList()
		end

		if #mobList > 0 then
			if index > #mobList then
				index = 1
			end

			local target = mobList[index]

			if target and target.Parent then
				hrp.CFrame = target.CFrame * CFrame.new(0,2,2)
			end

			holdTime = holdTime + dt
			if holdTime >= HOLD_DURATION then
				holdTime = 0
				index = index + 1
			end
		end
	end
end)

