--================ RETURN =================--

local function ClickReturnSafe()
    for i = 1,20 do
        local ui = player.PlayerGui:FindFirstChild("Results")
        if ui and ui.Enabled then
            local btn = ui:FindFirstChild("Return", true)
            if btn then
                firesignal(btn.MouseButton1Click)
            end
        end
        if not ui or not ui.Enabled then
            return true
        end
        task.wait(1)
    end
    return false
end

local function EnsureReturnCleared()
    repeat task.wait(1)
    until not player.PlayerGui:FindFirstChild("Results")
        or not player.PlayerGui.Results.Enabled
end

--================ AUTO RAID =================--

task.spawn(function()
    while task.wait(2) do
        if AutoRaid then

            CreateEaster()
            task.wait(2)
            StartEaster()

            repeat task.wait(1) until IsRaidFinished()
            ClickReturnSafe()
            EnsureReturnCleared()

            task.wait(5)

            CreateNormal()
            task.wait(2)
            StartNormal()

            repeat task.wait(1) until IsRaidFinished()
            ClickReturnSafe()
            EnsureReturnCleared()

            task.wait(5)
        end
    end
end)

