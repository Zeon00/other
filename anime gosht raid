--================ RAID CHECK =================--

local function GetRaid()
    local map = workspace:FindFirstChild("_MAP")
    if not map then return end

    local gm = map:FindFirstChild("Gamemode")
    if not gm then return end

    for _,v in pairs(gm:GetChildren()) do
        if string.find(v.Name,"Raid") then
            return v
        end
    end
end

local function IsInRaid()
    return GetRaid() ~= nil
end

local function IsRaidFinished()
    local ui = player.PlayerGui:FindFirstChild("Results")
    return ui and ui.Enabled
end

--================ SPOTS =================--

local function GetRaidSpots()
    local raid = GetRaid()
    if not raid then return {} end

    local spots = raid:FindFirstChild("Spots")
    if not spots then return {} end

    local list = {}
    for i = 1,10 do
        local s = spots:FindFirstChild(tostring(i))
        if s then
            table.insert(list, s)
        end
    end

    return list
end

--================ ENEMY CHECK =================--

local function IsEnemyNear(pos)
    for _,mob in pairs(EnemyFolder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        local hum = mob:FindFirstChild("Humanoid")

        if hrp and hum and hum.Health > 0 then
            if (hrp.Position - pos).Magnitude < 60 then
                return true
            end
        end
    end
    return false
end

--================ TP SPOT =================--

task.spawn(function()
    local index = 1
    local lastSwitch = 0

    while task.wait(0.2) do
        if TPEnemy and IsInRaid() then
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then continue end

            local root = char.HumanoidRootPart
            local spots = GetRaidSpots()

            if #spots > 0 then
                if index > #spots then
                    index = 1
                end

                local spot = spots[index]
                root.CFrame = spot.CFrame + Vector3.new(0,5,0)

                -- 🔥 FIX: pindah tiap 2 detik (bukan nunggu musuh)
                if tick() - lastSwitch > 2 then
                    index = index + 1
                    lastSwitch = tick()
                end
            end
        end
    end
end)

