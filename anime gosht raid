--// ENEMY
local EnemyFolder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")

--// SETTINGS
local AutoRaid = false
local TPEnemy = false
local Aura = false

local START_CF = CFrame.new(-3035,784,7447)
local RAID_DURATION = 900 -- 15 menit
local POST_DELAY = 600 -- 10 menit

--================ DETECT MAP =================--

-- Event map → untuk AutoRaid
local function InEventMap()
    local map = workspace:FindFirstChild("_MAP")
    return map and map:FindFirstChild("Easter 2026 Event")
end

-- Raid map → untuk TP & Aura
local function InRaid()
    local map = workspace:FindFirstChild("_MAP")
    if not map then return false end
    local gm = map:FindFirstChild("Gamemode")
    if not gm then return false end

    for _,v in pairs(gm:GetChildren()) do
        if string.find(v.Name, "Easter Raid") then
            return true
        end
    end
    return false
end

--================ FUNCTIONS =================--

-- Get nearest mob
local function GetNearest()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    local nearest, dist = nil, math.huge
    for _,mob in pairs(EnemyFolder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - root.Position).Magnitude
            if d < dist then
                dist = d
                nearest = hrp
            end
        end
    end
    return nearest
end

-- TP to target
local function TPTo(hrp)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0,0,4)
    end
end

-- Create raid
local function CreateRaid()
    RemoteEvent:FireServer({
        {
            "GamemodeSystem",
            "Create",
            "Easter Raid",
            "ChocolateKingdom",
            "Easy",
            true,
            n = 6
        },
        "\002"
    })
end

-- Start raid
local function StartRaid()
    RemoteEvent:FireServer({
        {
            "GamemodeSystem",
            "Start",
            "Easter Raid",
            8594485805,
            n = 4
        },
        "\002"
    })
end

-- Click return
local function ClickReturn()
    for i=1,20 do
        local results = player.PlayerGui:FindFirstChild("Results")
        if results and results.Enabled then
            local btn = results:FindFirstChild("Return", true)
            if btn then
                pcall(function()
                    firesignal(btn.MouseButton1Click)
                end)
                break
            end
        end
        task.wait(1)
    end
end

--================ LOOP TP ===================
task.spawn(function()
    while task.wait(0.2) do
        if TPEnemy and InRaid() then
            local target = GetNearest()
            if target then
                TPTo(target)
            end
        end
    end
end)

--================ LOOP AURA ===================
task.spawn(function()
    while task.wait() do
        if Aura and InRaid() then
            pcall(function()
                Remote:Fire("ClickSystem","Execute",Library.Target)
            end)
        end
    end
end)

--================ AUTO RAID LOOP ===================
task.spawn(function()
    while task.wait(1) do
        if AutoRaid and InEventMap() then

            -- pastikan character ready
            repeat task.wait()
                local c = player.Character
            until c and c:FindFirstChild("HumanoidRootPart")

            local char = player.Character
            char.HumanoidRootPart.CFrame = START_CF

            task.wait(2)

            -- create + start
            CreateRaid()
            task.wait(2)
            StartRaid()

            -- delay masuk raid
            task.wait(15)

            -- durasi raid
            task.wait(RAID_DURATION)

            -- tunggu results UI
            repeat task.wait(1)
                local results = player.PlayerGui:FindFirstChild("Results")
            until results and results.Enabled

            -- klik return
            ClickReturn()

            -- tunggu UI hilang
            repeat task.wait(1)
                local results = player.PlayerGui:FindFirstChild("Results")
            until not results or not results.Enabled

            -- delay 10 menit sebelum ulang
            task.wait(POST_DELAY)

        end
    end
end)

