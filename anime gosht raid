--// SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

--// LIB
local Library = require(RS:WaitForChild("Framework"):WaitForChild("Library"))
local Remote = Library.Remote

--// REMOTE
local RemoteEvent = RS:WaitForChild("ffrostflame_bridgenet2@1.0.0"):WaitForChild("dataRemoteEvent")

--// SETTINGS
local AutoRaid = false
local TPEnemy = false
local Aura = false

local START_CF = CFrame.new(-3035,784,7447)
local RAID_DURATION = 900
local POST_DELAY = 600

--================ DETECT =================--

local function InEventMap()
    local map = workspace:FindFirstChild("_MAP")
    return map and map:FindFirstChild("Easter 2026 Event")
end

local function GetRaid()
    local map = workspace:FindFirstChild("_MAP")
    if not map then return end
    local gm = map:FindFirstChild("Gamemode")
    if not gm then return end

    for _,v in pairs(gm:GetChildren()) do
        if string.find(v.Name, "Easter Raid") then
            return v
        end
    end
end

local function InRaid()
    return GetRaid() ~= nil
end

--================ SPOT SYSTEM =================--

local function GetRaidSpots()
    local raid = GetRaid()
    if not raid then return {} end

    local spots = raid:FindFirstChild("Spots")
    return spots and spots:GetChildren() or {}
end

local function IsInRaidArea(pos)
    for _,spot in pairs(GetRaidSpots()) do
        if (spot.Position - pos).Magnitude < 80 then
            return true
        end
    end
    return false
end

--================ TARGET =================--

local function GetNearest()
    local folder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")

    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart

    local nearest, dist = nil, math.huge

    for _,mob in pairs(folder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")

        if hrp and IsInRaidArea(hrp.Position) then
            local d = (hrp.Position - root.Position).Magnitude
            if d < dist and d < 200 then
                dist = d
                nearest = hrp
            end
        end
    end

    return nearest
end

local function TPTo(hrp)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(0,0,4)
    end
end

--================ RAID =================--

local function CreateRaid()
    RemoteEvent:FireServer({
        {
            "GamemodeSystem",
            "Create",
            "Easter Raid",
            "ChocolateKingdom",
            "Easy",
            true,
            n = 6
        },
        "\002"
    })
end

local function StartRaid()
    RemoteEvent:FireServer({
        {
            "GamemodeSystem",
            "Start",
            "Easter Raid",
            8594485805,
            n = 4
        },
        "\002"
    })
end

local function ClickReturn()
    for i=1,20 do
        local results = player.PlayerGui:FindFirstChild("Results")
        if results and results.Enabled then
            local btn = results:FindFirstChild("Return", true)
            if btn then
                pcall(function()
                    firesignal(btn.MouseButton1Click)
                end)
                break
            end
        end
        task.wait(1)
    end
end

--================ LOOP TP =================--

task.spawn(function()
    while task.wait(0.2) do
        if TPEnemy and InRaid() then
            local target = GetNearest()
            if target then
                TPTo(target)
            end
        end
    end
end)

--================ LOOP AURA =================--

task.spawn(function()
    while task.wait() do
        if Aura and InRaid() then
            pcall(function()
                Remote:Fire("ClickSystem","Execute",Library.Target)
            end)
        end
    end
end)

--================ AUTO RAID =================--

task.spawn(function()
    while task.wait(1) do
        if AutoRaid and InEventMap() then

            repeat task.wait()
                local c = player.Character
            until c and c:FindFirstChild("HumanoidRootPart")

            player.Character.HumanoidRootPart.CFrame = START_CF
            task.wait(2)

            CreateRaid()
            task.wait(2)
            StartRaid()

            -- delay masuk raid
            task.wait(15)

            -- durasi raid
            task.wait(RAID_DURATION)

            ClickReturn()

            -- delay sebelum ulang
            task.wait(POST_DELAY)
        end
    end
end)

