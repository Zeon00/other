--================ RAID DETECT =================--

local function GetRaid()
    local gm = workspace:FindFirstChild("_MAP")
    if not gm then return end
    gm = gm:FindFirstChild("Gamemode")
    if not gm then return end

    for _,v in pairs(gm:GetChildren()) do
        if string.find(v.Name,"Raid") then
            return v
        end
    end
end

local function GetSpots()
    local raid = GetRaid()
    if not raid then return {} end
    local s = raid:FindFirstChild("Spots")
    return s and s:GetChildren() or {}
end

--================ ENEMY =================--

local function GetNearest()
    local folder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local root = char.HumanoidRootPart
    local nearest, dist = nil, math.huge

    for _,mob in pairs(folder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            local d = (hrp.Position - root.Position).Magnitude
            if d < dist then
                dist = d
                nearest = mob
            end
        end
    end

    return nearest
end

local function IsSpotClear(pos)
    local folder = workspace:WaitForChild("_ENEMIES"):WaitForChild("Client")

    for _,mob in pairs(folder:GetChildren()) do
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - pos).Magnitude < 70 then
            return false
        end
    end

    return true
end


