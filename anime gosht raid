--================ RETURN =================--

local function ClickReturn()
    for i=1,15 do
        local ui = player.PlayerGui:FindFirstChild("Results")
        if ui and ui.Enabled then
            local btn = ui:FindFirstChild("Return", true)
            if btn then
                firesignal(btn.MouseButton1Click)
                break
            end
        end
        task.wait(1)
    end
end

--================ AUTO RAID =================--

