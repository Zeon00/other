local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.Text = "RAID PANEL"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1

local function Toggle(name,pos,callback)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(1,-20,0,40)
    b.Position = UDim2.new(0,10,0,pos)
    b.Text = name.." OFF"
    b.BackgroundColor3 = Color3.fromRGB(60,60,60)
    b.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", b)

    local state = false
    b.MouseButton1Click:Connect(function()
        state = not state
        b.Text = name.." "..(state and "ON" or "OFF")
        b.BackgroundColor3 = state and Color3.fromRGB(0,170,0) or Color3.fromRGB(60,60,60)
        callback(state)
    end)
end

Toggle("Auto Raid",40,function(v) AutoRaid = v end)
Toggle("TP Enemy (Raid)",90,function(v) TPEnemy = v end)
Toggle("Kill Aura",140,function(v) Aura = v end)
