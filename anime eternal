-- GET MOBS
local function getMobs()
	local mobs = {}
	local folder = Workspace:FindFirstChild("Debris") and Workspace.Debris:FindFirstChild("Monsters")
	if folder then
		for _, m in pairs(folder:GetChildren()) do
			if m:FindFirstChild("HumanoidRootPart") and m:FindFirstChild("Humanoid") then
				table.insert(mobs, m)
			end
		end
	end
	return mobs
end

-- MAIN LOOP
RunService.RenderStepped:Connect(function()
	if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end

	local myHRP = player.Character.HumanoidRootPart

	-- PRIORITY
	if KillAura then
		Status.Text = "Status: Farming"

		local target = nil
		local distMin = math.huge

		for _, mob in pairs(getMobs()) do
			local hrp = mob.HumanoidRootPart
			local hum = mob.Humanoid

			if hum.Health > 0 then
				local dist = (myHRP.Position - hrp.Position).Magnitude

				if dist <= MAX_DISTANCE then
					if dist < distMin then
						distMin = dist
						target = mob
					end
				end
			end
		end

		if target then
			local hrp = target.HumanoidRootPart

			if distMin > 15 then
				myHRP.CFrame = hrp.CFrame * CFrame.new(0,0,3)
			end

			for i = 1,5 do
				Remote:FireServer(unpack({{
					Id = target.Name,
					Action = "_Mouse_Click"
				}}))
			end
		else
			Status.Text = "Status: No Mob Nearby"
		end

	elseif AutoTrain then
		Status.Text = "Status: Training"

		for i = 1,5 do
			Remote:FireServer(unpack({{Action = "_Mouse_Click"}}))
		end

	else
		Status.Text = "Status: Idle"
	end
end)
