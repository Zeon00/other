--// LOOP
local function start()
	if running then return end
	running = true

	while running do
		if aura or vacuum then
			local mob = getClosestMob()

			if mob then
				if vacuum then
					vacuumMob(mob)
				end

				if aura then
					hitMob(mob)
				end
			end
		end

		task.wait(0.08)
	end
end

start()
