--// SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")

local Remote = RS:WaitForChild("Events"):WaitForChild("To_Server")

--// STATE
local aura = false
local vacuum = false
local running = false

--// GET MOB TERDEKAT
local function getClosestMob()
	local closest = nil
	local dist = math.huge

	for _, mob in pairs(Workspace:WaitForChild("Debris"):WaitForChild("Monsters"):GetChildren()) do
		if mob:FindFirstChild("HumanoidRootPart") then
			local d = (mob.HumanoidRootPart.Position - hrp.Position).Magnitude
			if d < dist then
				dist = d
				closest = mob
			end
		end
	end

	return closest
end

--// VACUUM (SMOOTH)
local function vacuumMob(mob)
	if mob and mob:FindFirstChild("HumanoidRootPart") then
		local targetPos = mob.HumanoidRootPart.Position
		local distance = (hrp.Position - targetPos).Magnitude

		if distance > 4 then
			local targetCFrame = CFrame.new(targetPos + Vector3.new(0,0,3))
			hrp.CFrame = hrp.CFrame:Lerp(targetCFrame, 0.25)
		end
	end
end

--// HIT
local function hitMob(mob)
	if not mob or not mob:FindFirstChild("HumanoidRootPart") then return end
	
	local distance = (hrp.Position - mob.HumanoidRootPart.Position).Magnitude
	
	if distance > 3 then
		hrp.CFrame = CFrame.lookAt(hrp.Position, mob.HumanoidRootPart.Position)
	end

	for i = 1,15 do
		Remote:FireServer({
			Id = mob.Name,
			Action = "_Mouse_Click"
		})
	end
end

