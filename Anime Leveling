local UIS = game:GetService("UserInputService")

local function MakeDraggable(frame)
    local dragging = false
    local dragStart
    local startPos

    local function startDrag(input)
        dragging = true
        dragStart = input.Position
        startPos = frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end

    -- 🔥 DETECT DARI FRAME + SEMUA CHILD
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 
        or input.UserInputType == Enum.UserInputType.Touch then
            startDrag(input)
        end
    end)

    for _, v in pairs(frame:GetDescendants()) do
        if v:IsA("GuiObject") then
            v.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 
                or input.UserInputType == Enum.UserInputType.Touch then
                    startDrag(input)
                end
            end)
        end
    end

    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement 
        or input.UserInputType == Enum.UserInputType.Touch) then

            local delta = input.Position - dragStart

            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end
-- ENEMY LIST (UNCHANGED)
local function UpdateEnemyList()
    local enemies = GetEnemies()
    local used = {}

    for _, child in pairs(scrollMob:GetChildren()) do
        if child:IsA("Frame") and child.Name == "EnemyCheckbox" then
            child:Destroy()
        end
    end

    for _, enemy in pairs(enemies) do
        local name = enemy.Name
        if not used[name] then
            used[name] = true

            local f = Instance.new("Frame", scrollMob)
            f.Name = "EnemyCheckbox"
            f.Size = UDim2.new(0.9,0,0,30)
            f.BackgroundColor3 = Color3.fromRGB(40,40,40)
            Instance.new("UICorner", f)

            local txt = Instance.new("TextLabel", f)
            txt.Size = UDim2.new(0.65,0,1,0)
            txt.Text = name
            txt.TextColor3 = Color3.new(1,1,1)
            txt.BackgroundTransparency = 1
            txt.Font = Enum.Font.Gotham
            txt.TextScaled = true

            local btn = Instance.new("TextButton", f)
            btn.Size = UDim2.new(0.35,0,1,0)
            btn.Position = UDim2.new(0.65,0,0,0)
            btn.TextColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", btn)

            SelectedEnemies[name] = SelectedEnemies[name] or false

            local function Refresh()
                btn.Text = SelectedEnemies[name] and "ON" or "OFF"
                btn.BackgroundColor3 = SelectedEnemies[name]
                    and Color3.fromRGB(0,150,0)
                    or Color3.fromRGB(120,0,0)
            end

            Refresh()

            btn.MouseButton1Click:Connect(function()
                SelectedEnemies[name] = not SelectedEnemies[name]
                Refresh()
            end)
        end
    end
end

