-- TOGGLE FUNCTION
local function Toggle(name, callback)
    local btn = Instance.new("TextButton", scrollToggle)
    btn.Size = UDim2.new(0.9,0,0,36)
    btn.Text = name.." OFF"
    btn.Font = Enum.Font.Gotham
    btn.TextScaled = true
    btn.BackgroundColor3 = Color3.fromRGB(80,0,0)
    btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn)
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name.." "..(state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(0,150,0) or Color3.fromRGB(80,0,0)
        callback(state)
    end)
end

-- ENEMY LIST
local function UpdateEnemyList()
    local enemies = GetEnemies()
    for _, child in pairs(scrollMob:GetChildren()) do
        if child:IsA("Frame") and child.Name == "EnemyCheckbox" then
            child:Destroy()
        end
    end
    for _, enemy in pairs(enemies) do
        local name = enemy.Name
        local f = Instance.new("Frame", scrollMob)
        f.Name = "EnemyCheckbox"
        f.Size = UDim2.new(0.9,0,0,30)
        f.BackgroundColor3 = Color3.fromRGB(40,40,40)
        Instance.new("UICorner", f)

        local txt = Instance.new("TextLabel", f)
        txt.Size = UDim2.new(0.65,0,1,0)
        txt.Text = name
        txt.TextColor3 = Color3.new(1,1,1)
        txt.BackgroundTransparency = 1
        txt.Font = Enum.Font.Gotham
        txt.TextScaled = true

        local btn = Instance.new("TextButton", f)
        btn.Size = UDim2.new(0.35,0,1,0)
        btn.Position = UDim2.new(0.65,0,0,0)
        btn.Text = "OFF"
        btn.BackgroundColor3 = Color3.fromRGB(120,0,0)
        btn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", btn)
        SelectedEnemies[name] = SelectedEnemies[name] or false
        btn.MouseButton1Click:Connect(function()
            SelectedEnemies[name] = not SelectedEnemies[name]
            btn.Text = SelectedEnemies[name] and "ON" or "OFF"
            btn.BackgroundColor3 = SelectedEnemies[name] and Color3.fromRGB(0,150,0) or Color3.fromRGB(120,0,0)
        end)
    end
end

task.spawn(function()
    while task.wait(3) do
        pcall(UpdateEnemyList)
    end
end)

-- MAIN LOOP
local index = 1
RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local enemies = GetEnemies()
    local targets = {}
    for _, enemy in pairs(enemies) do
        if SelectedEnemies[enemy.Name] then
            table.insert(targets, enemy)
        end
    end

    if #targets > 0 then
        index = index % #targets + 1
        local target = targets[index]
        local ehrp = target:FindFirstChild("HumanoidRootPart")
        local hum = target:FindFirstChildOfClass("Humanoid")
        if ehrp and hum and hum.Health > 0 then
            if AutoTP then
                hrp.CFrame = hrp.CFrame:Lerp(ehrp.CFrame * CFrame.new(0,2,0), 0.8)
            end
            if FastHit then
                ClickRemote:FireServer()
                ClickRemote:FireServer()
            end
        end
    end

    if AutoRaid then DoRaid() end
    if AutoFruit then Remotes.RollFruitPower:FireServer() end
    if AutoHaki then Remotes.HakiLeveling:FireServer() end
    if AutoDragon then Remotes.RollDragonBallPower:FireServer() end
    if AutoSaiyan then Remotes.RollSaiyanPower:FireServer() end
    if AutoEgg then Remotes.Eggs.Hatch:InvokeServer("Star4", 10) end
    if AutoBreathing then Remotes.RollBreathingPower:FireServer() end
    if AutoProsperity then Remotes.RollProsperityPower:FireServer() end
    if AutoGrimoire then Remotes.RollGrimoiresPower:FireServer() end
    if AutoDemon then Remotes.RollDemonPower:FireServer() end
end)

