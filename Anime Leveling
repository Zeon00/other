local function IsInWanden()
    local raid = workspace:FindFirstChild("WandenreichRaid")
    if not raid then return false end

    for _, v in pairs(raid:GetChildren()) do
        if v:IsA("Folder") and v:FindFirstChild("Enemy") then
            local enemies = v:FindFirstChild("Enemy")
            if enemies and #enemies:GetChildren() > 0 then
                return true -- ✅ ada musuh = lagi raid
            end
        end
    end

    return false
end

