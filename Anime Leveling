--// SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local Remotes = RS:WaitForChild("Remotes")
local ClickRemote = Remotes:WaitForChild("Clicked")
local State = require(RS.Client.State) -- TIDAK DIUBAH

--// STATE
local FastHit, AutoTP, BypassAll = false,false,false
local AutoFruit, AutoHaki, AutoDragon = false,false,false
local AutoSaiyan, AutoEgg = false,false
local AutoRaid = false

local AutoBreathing = false
local AutoProsperity = false
local AutoGrimoire = false
local AutoDemon = false

--// AUTO RAID FUNCTION (BASIC)
local function DoRaid()
    pcall(function()
        local raid = Remotes:FindFirstChild("StartRaid")
        if raid then
            raid:FireServer("TowerRaid")
        end
    end)
end

Remotes:WaitForChild("EndRaid").OnClientEvent:Connect(function()
    if AutoRaid then
        task.wait(3)
        DoRaid()
    end
end)

--// GET ENEMIES
local function GetEnemies()
    local data = State.GetData()
    if not data or not data.LastArea then return {} end

    local folder
    if data.LastArea == "WisteriaRaid" or data.LastArea == "TowerRaid" then
        local raid = workspace:FindFirstChild(data.LastArea)
        if raid then
            local area = raid:FindFirstChild(data.RaidArea)
            if area then folder = area:FindFirstChild("Enemy") end
        end
    else
        local world = workspace:FindFirstChild(data.LastArea)
        if world then folder = world:FindFirstChild("Enemy") end
    end

    if not folder then return {} end

    local list = {}
    for _, enemy in pairs(folder:GetChildren()) do
        local ehrp = enemy:FindFirstChild("HumanoidRootPart")
        local hum = enemy:FindFirstChildOfClass("Humanoid")
        if ehrp and hum and hum.Health > 0 then
            table.insert(list, enemy)
        end
    end
    return list
end

--// LOOP (ASLI + FIX TP)
local index = 1
local lastTP = 0
local TP_DELAY = 0.4 -- 🔥 BIAR GA NGACO

RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local enemies = GetEnemies()
    if #enemies > 0 then
        if index > #enemies then index = 1 end
        local enemy = enemies[index]
        index = index + 1

        if enemy then
            local ehrp = enemy:FindFirstChild("HumanoidRootPart")
            local hum = enemy:FindFirstChildOfClass("Humanoid")

            if ehrp and hum and hum.Health > 0 then
                
                -- ✅ FIX TP (INI DOANG YG DIUBAH)
                if AutoTP and tick() - lastTP > TP_DELAY then
                    hrp.CFrame = ehrp.CFrame * CFrame.new(0,2,0)
                    lastTP = tick()
                end

                if FastHit then
                    ClickRemote:FireServer()
                    ClickRemote:FireServer()
                end
            end
        end
    end

    -- AUTO RAID LOOP
    if AutoRaid then
        DoRaid()
    end

    -- EXTRA (TIDAK DIUBAH)
    if AutoFruit then Remotes.RollFruitPower:FireServer() end
    if AutoHaki then Remotes.HakiLeveling:FireServer() end
    if AutoDragon then Remotes.RollDragonBallPower:FireServer() end
    if AutoSaiyan then Remotes.RollSaiyanPower:FireServer() end
    if AutoEgg then Remotes.Eggs.Hatch:InvokeServer("Star4", 10) end

    if AutoBreathing then Remotes.RollBreathingPower:FireServer() end
    if AutoProsperity then Remotes.RollProsperityPower:FireServer() end
    if AutoGrimoire then Remotes.RollGrimoiresPower:FireServer() end
    if AutoDemon then Remotes.RollDemonPower:FireServer() end
end)

--// BYPASS (TIDAK DIUBAH)
local Shop = require(RS.ModuleScripts:WaitForChild("Shop"))
local oldOwn = Shop.DoesPlayerOwnGamepass
Shop.DoesPlayerOwnGamepass = function(name, data)
    if BypassAll then return true end
