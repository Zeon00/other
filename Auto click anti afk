--// LOGIC
local function getHRP()
    local c = player.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function isSelected(name)
    local base = getBaseName(name)
    return Selected[base]
end

local function getTargetMob()
    local closest, dist = nil, math.huge
    local hrp = getHRP()
    if not hrp then return end

    for _, mob in pairs(workspace.Mobs:GetChildren()) do
        if isSelected(mob.Name) then
            local mHRP = mob:FindFirstChild("HumanoidRootPart")
            if mHRP then
                local d = (mHRP.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = mob
                end
            end
        end
    end

    return closest
end

RunService.RenderStepped:Connect(function()
    local hrp = getHRP()
    if not hrp then return end

    local mob = getTargetMob()
    if not mob then return end

    local mHRP = mob:FindFirstChild("HumanoidRootPart")
    if not mHRP then return end

    if AutoTP then
        hrp.CFrame = mHRP.CFrame * CFrame.new(0,0,-3)
    end

    if KillAura then
        pcall(function()
            ClickRemote:InvokeServer(mob.Name)
        end)
    end
end)
