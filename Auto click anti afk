-- ICON
local Icon = Instance.new("TextButton", ScreenGui)
Icon.Size = UDim2.new(0,50,0,50)
Icon.Position = Frame.Position
Icon.Text = "AC"
Icon.Visible = false
Icon.Font = Enum.Font.GothamBold
Icon.TextColor3 = Color3.new(1,1,1)
Icon.BackgroundColor3 = Color3.fromRGB(30,30,30)
Instance.new("UICorner", Icon).CornerRadius = UDim.new(1,0)

--// FUNCTIONS

-- TOGGLE
Toggle.MouseButton1Click:Connect(function()
    AutoClick = not AutoClick
    Toggle.Text = AutoClick and "ON" or "OFF"
    Toggle.BackgroundColor3 = AutoClick and Color3.fromRGB(0,170,100) or Color3.fromRGB(50,50,50)
end)

-- CLOSE
Close.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
    getgenv()["AC_GUI"] = false
end)

-- MINIMIZE
Min.MouseButton1Click:Connect(function()
    Frame.Visible = false
    Icon.Visible = true
    Icon.Position = Frame.Position
end)

-- RESTORE
Icon.MouseButton1Click:Connect(function()
    Frame.Visible = true
    Icon.Visible = false
end)

-- DRAG
local drag, dragInput, startPos, startFrame

Top.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true
        startPos = input.Position
        startFrame = Frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                drag = false
            end
        end)
    end
end)

Top.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and drag then
        local delta = input.Position - startPos
        Frame.Position = UDim2.new(
            startFrame.X.Scale,
            startFrame.X.Offset + delta.X,
            startFrame.Y.Scale,
            startFrame.Y.Offset + delta.Y
        )
    end
end)

--// AUTO CLICK LOOP (ANTI AFK PURE CLICK)
task.spawn(function()
    while true do
        if AutoClick then
            local pos = UIS:GetMouseLocation()

            VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 0)
            VIM:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 0)

            -- delay random biar natural
            task.wait(math.random(DelayMin, DelayMax))
        else
            task.wait(0.1)
        end
    end
end)
