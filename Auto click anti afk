--------------------------------------------------
-- UPDATE LIST MOB
--------------------------------------------------
local function UpdateEnemyList()
    local enemies = GetEnemies()
    local used = {}

    for _, v in pairs(scroll:GetChildren()) do
        if v:IsA("Frame") then
            v:Destroy()
        end
    end

    for _, enemy in pairs(enemies) do
        local name = enemy.Name:gsub("_%d+","")

        if not used[name] then
            used[name] = true

            local f = Instance.new("Frame", scroll)
            f.Size = UDim2.new(1,0,0,30)
            f.BackgroundColor3 = Color3.fromRGB(40,40,40)
            Instance.new("UICorner", f)

            local txt = Instance.new("TextLabel", f)
            txt.Size = UDim2.new(0.6,0,1,0)
            txt.Text = name
            txt.TextColor3 = Color3.new(1,1,1)
            txt.BackgroundTransparency = 1

            local btn = Instance.new("TextButton", f)
            btn.Size = UDim2.new(0.4,0,1,0)
            btn.Position = UDim2.new(0.6,0,0,0)

            SelectedEnemies[name] = SelectedEnemies[name] or false

            local function Refresh()
                btn.Text = SelectedEnemies[name] and "ON" or "OFF"
                btn.BackgroundColor3 = SelectedEnemies[name]
                    and Color3.fromRGB(0,150,0)
                    or Color3.fromRGB(100,0,0)
            end

            Refresh()

            btn.MouseButton1Click:Connect(function()
                SelectedEnemies[name] = not SelectedEnemies[name]
                Refresh()
            end)
        end
    end
end

task.spawn(function()
    while task.wait(2) do
