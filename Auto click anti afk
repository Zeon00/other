--------------------------------------------------
-- GET HRP
--------------------------------------------------
local function GetHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

--------------------------------------------------
-- GET ENEMIES (FIX: CLIENT ENEMIES)
--------------------------------------------------
local function GetEnemies()
    local list = {}

    local folder = workspace:FindFirstChild("Client")
    folder = folder and folder:FindFirstChild("Enemies")

    if not folder then return list end

    for _, enemy in pairs(folder:GetChildren()) do
        local hrp = enemy:FindFirstChild("HumanoidRootPart")
        local hum = enemy:FindFirstChildOfClass("Humanoid")

        if hrp and hum and hum.Health > 0 and hrp.Position.Y > 0 then
            table.insert(list, enemy)
        end
    end

    return list
end

--------------------------------------------------
-- SAFE TP (ANTI VOID)
--------------------------------------------------
local function SafeTP(cf)
    local ray = Ray.new(cf.Position, Vector3.new(0, -100, 0))
    local part, pos = workspace:FindPartOnRay(ray)

    if part and pos then
        return CFrame.new(pos + Vector3.new(0, 3, 0))
    end

    return nil
end

--------------------------------------------------
-- VALID MOB
--------------------------------------------------
local function IsMobReady(enemy)
    if not enemy then return false end

    local hrp = enemy:FindFirstChild("HumanoidRootPart")
    local hum = enemy:FindFirstChildOfClass("Humanoid")

    if not hrp or not hum then return false end
    if hum.Health <= 0 then return false end
    if hrp.Position.Y < 0 then return false end

    return true
end

