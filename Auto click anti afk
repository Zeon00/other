--------------------------------------------------
-- MAIN LOOP
--------------------------------------------------
local lastTP = 0
local index = 1

RunService.Heartbeat:Connect(function()
    local myhrp = GetHRP()
    if not myhrp then return end

    local enemies = GetEnemies()
    local targets = {}

    -- NEAREST MODE
    if _G.AutoTPNearest then
        local nearest, dist = nil, math.huge

        for _, e in pairs(enemies) do
            if IsMobReady(e) then
                local hrp = e:FindFirstChild("HumanoidRootPart")
                local d = (myhrp.Position - hrp.Position).Magnitude

                if d < dist then
                    dist = d
                    nearest = e
                end
            end
        end

        if nearest then
            table.insert(targets, nearest)
        end

    -- SELECT MODE
    else
        for _, e in pairs(enemies) do
            local name = e.Name:gsub("_%d+","")
            if SelectedEnemies[name] then
                table.insert(targets, e)
            end
        end
    end

    if #targets > 0 then
        index = index % #targets + 1
        local target = targets[index]

        local hrp = target:FindFirstChild("HumanoidRootPart")

        if hrp and tick() - lastTP > 0.2 then
            local safe = SafeTP(hrp.CFrame)

            if safe then
                myhrp.CFrame = safe
                lastTP = tick()
            end
        end
    end
end)

