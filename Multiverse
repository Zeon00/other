--// SMART DPS LOOP
task.spawn(function()
    local delay = 0.04 -- start stabil

    while true do
        if ON then
            local target = getTarget()

            if target then
                local success = 0

                -- burst kecil tapi konsisten
                for i = 1,2 do
                    local ok = pcall(function()
                        MonsterRemote:FireServer("DamToMonster", target, {
                            damtype = "normal"
                        })
                    end)
                    if ok then
                        success = success + 1
                    end
                end

                -- AUTO ADJUST SPEED
                if success < 2 then
                    delay = math.clamp(delay + 0.005, 0.03, 0.08)
                else
                    delay = math.clamp(delay - 0.002, 0.03, 0.08)
                end
            end
        end

        task.wait(delay)
    end
end)

