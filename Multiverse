--// TOGGLE CREATOR
local function createToggle(text, posY)
    local btn = Instance.new("TextButton", Frame)
    btn.Size = UDim2.new(0.8,0,0,35)
    btn.Position = UDim2.new(0.1,0,posY,0)
    btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    btn.Text = text .. ": ON"
    return btn
end

local ToggleKill = createToggle("Kill Aura", 0.25)
local ToggleTP = createToggle("Auto Farm", 0.5)
local ToggleAFK = createToggle("Anti AFK", 0.75)

local KillON, TPON, AFKON = true, true, true

ToggleKill.Activated:Connect(function()
