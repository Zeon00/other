local MonsterRemote = RS:WaitForChild("Remotes"):WaitForChild("MonsterEvent")
local TaskRemote = RS:WaitForChild("Remotes"):WaitForChild("DataInterface"):WaitForChild("Task")

--// STATE
local KillON = true
local WalkON = true
local AFKON = true
local DGON = true

--// GET TARGET
local function getTarget()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local room = char.Parent and char.Parent.Parent
    if not room then return end

    local folder = room:FindFirstChild("Monster_")
    if not folder then return end

    local closest, dist = nil, math.huge

    for _,mob in pairs(folder:GetChildren()) do
        local mhrp = mob:FindFirstChild("HumanoidRootPart")
        if mhrp then
            local d = (hrp.Position - mhrp.Position).Magnitude
            if d < dist then
                dist = d
                closest = mob
            end
        end
    end

    return closest
end

--// DETEK DUNGEON
local function inDungeon()
    local char = player.Character
    if not char then return false end
    local room = char.Parent and char.Parent.Parent
    if not room then return false end
    return room:FindFirstChild("Monster_") ~= nil
end

--// MASUK DUNGEON
local function enterDungeon()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local tpPart = workspace.ForScript.Entrance.World5.Party5.tpPart
    if tpPart then
        hrp.CFrame = tpPart.CFrame + Vector3.new(0,3,0)
    end
end

