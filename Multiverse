--// DPS LOOP (LOGIC LO TETAP)
task.spawn(function()
    local delay = 0.04

    while true do
        if KillON then
            local target = getTarget()

            if target then
                local success = 0

                for i = 1,2 do
                    local ok = pcall(function()
                        MonsterRemote:FireServer("DamToMonster", target, {
                            damtype = "normal"
                        })
                    end)
                    if ok then
                        success = success + 1
                    end
                end

                if success < 2 then
                    delay = math.clamp(delay + 0.005, 0.03, 0.08)
                else
                    delay = math.clamp(delay - 0.002, 0.03, 0.08)
                end
            end
        end

        task.wait(delay)
    end
end)

--// FAST WALK
task.spawn(function()
    while true do
        if WalkON then
            local char = player.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local target = getTarget()

            if hum and hrp and target then
                hum.WalkSpeed = 60
                hum:MoveTo(target.HumanoidRootPart.Position)
            end
        end

        task.wait(0.2)
    end
end)

--// ANTI AFK
task.spawn(function()
    while true do
        if AFKON then
            pcall(function()
                TaskRemote:FireServer("slash")
            end)
        end
        task.wait(25)
    end
end)
