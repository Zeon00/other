--// KILL
task.spawn(function()
    while true do
        if KillON then
            local t = getTarget()
            if t then
                MonsterRemote:FireServer("DamToMonster",t,{damtype="normal"})
            end
        end
        task.wait(0.05)
    end
end)

--// WALK
task.spawn(function()
    while true do
        if WalkON then
            local char = player.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local t = getTarget()
            if hum and t then
                hum.WalkSpeed = 60
                hum:MoveTo(t.HumanoidRootPart.Position)
            end
        end
        task.wait(0.2)
    end
end)

