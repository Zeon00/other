--// GET SERVER MONSTER
local function getServerMonster()
    for _, mob in pairs(workspace:WaitForChild("Monsters"):GetChildren()) do
        local id = tonumber(mob.Name:match("Monster_(%d+)"))
        if id then
            return mob, id
        end
    end
end

--// GET CLIENT MONSTER
local function getClientMonster(id)
    local mob = workspace:WaitForChild("ClientMonsters"):FindFirstChild("Monster_"..id)
    if mob and mob:FindFirstChild("Shower") and mob.Shower:FindFirstChild("HumanoidRootPart") then
        return mob.Shower.HumanoidRootPart
    end
end

--// ATTACK LOOP
task.spawn(function()
    while true do
        if AutoAttack then
            local _, id = getServerMonster()
            if id then
                Remote:InvokeServer("AttackMonsterChannel", {id})
            end
        end
        task.wait(0.05)
    end
end)

--// TP LOOP (SMOOTH NO SHAKE)
task.spawn(function()
    while true do
        if AutoTP and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local _, id = getServerMonster()
            if id then
                local hrp = getClientMonster(id)
                if hrp then
                    local myHRP = player.Character.HumanoidRootPart
                    local targetPos = hrp.Position + Vector3.new(0,0,3)

                    local dist = (myHRP.Position - targetPos).Magnitude
                    
                    if dist > 6 then
                        local tween = TweenService:Create(
                            myHRP,
                            TweenInfo.new(0.15, Enum.EasingStyle.Linear),
                            {CFrame = CFrame.new(targetPos)}
                        )
                        tween:Play()
                    end
                end
            end
        end
        task.wait(0.2)
    end
end)

