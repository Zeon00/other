-- get nearest tree
local function getNearestTree()

local char=player.Character
if not char then return end

local root=char:FindFirstChild("HumanoidRootPart")
if not root then return end

local nearest=nil
local dist=math.huge

for _,tree in pairs(treesFolder:GetChildren()) do
if tree:GetAttribute("Destroyed")~=true then
local bound=tree:FindFirstChild("XZBounds")
if bound then
local d=(root.Position-bound.Position).Magnitude
if d<dist then
dist=d
nearest=bound
end
end
end
end

return nearest

end

-- move to tree
local function moveToTree(bound)

local char=player.Character
if not char then return end

local root=char:FindFirstChild("HumanoidRootPart")
if not root then return end

local dir=(root.Position-bound.Position).Unit
local pos=bound.Position+dir*6+Vector3.new(0,2,0)

root.AssemblyLinearVelocity=Vector3.zero
root.AssemblyAngularVelocity=Vector3.zero

char:PivotTo(CFrame.new(pos,bound.Position))

end

