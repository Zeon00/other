-- nearest tree
local function getNearestTree()

	local char = player.Character
	if not char then return end

	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local nearest
	local dist = math.huge

	for _,tree in pairs(treesFolder:GetChildren()) do

		if tree:GetAttribute("Destroyed") ~= true then

			local bound = tree:FindFirstChild("XZBounds")

			if bound then

				local d = (root.Position-bound.Position).Magnitude

				if d < dist then
					dist = d
					nearest = bound
				end

			end

		end

	end

	return nearest

end

local function moveToTree(bound)

	local char = player.Character
	if not char then return end

	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	root.CFrame = bound.CFrame + Vector3.new(0,2,6)

end

-- main loop
task.spawn(function()

	while not destroyed do

		if buy then
			for i=1,13 do
				pcall(function()
					buyRemote:InvokeServer("Atomic",i)
				end)
				task.wait(0.15)
			end
		end

		if chop then

			local bound = getNearestTree()

			if bound then

				moveToTree(bound)

				local tree = bound.Parent

				repeat

					pcall(function()
						chopRemote:InvokeServer(bound)
					end)

					task.wait(0.03)

				until tree:GetAttribute("Destroyed")==true or not chop

			end

		end

		if chest then
			pcall(function()
				chestRemote:InvokeServer("AtomicChest")
			end)
		end

		if chaosSpin then
			pcall(function()
				spinRemote:InvokeServer("Chaos Fortune","x25")
			end)
		end

		if gift then
			pcall(function()
				giftRemote:InvokeServer("23")
			end)
		end

		if refineryAdd then
			pcall(function()
				refineryAddRemote:InvokeServer("WildWest")
			end)
		end

		if refineryClaim then
			pcall(function()
				refineryClaimRemote:InvokeServer("WildWest")
			end)
		end

		if egyptSpin then
			pcall(function()
				spinRemote:InvokeServer("Egyptian Fortune","x25")
			end)
		end

		task.wait(1)

	end

end)

