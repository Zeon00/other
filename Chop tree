local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

local remote = ReplicatedStorage
:WaitForChild("Packages")
:WaitForChild("Knit")
:WaitForChild("Services")
:WaitForChild("ChaosBreakablesService")
:WaitForChild("RF")
:WaitForChild("Clicked")

local treesFolder = workspace.GameObjects.ChaosBreakables:WaitForChild("Axe")

local delay = 0.04
local running = false
local stayRadius = 4

local function getRoot()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

local function teleportInside(bound)

	local root = getRoot()
	if not root then return end
	
	local center = bound.Position
	local offset = bound.CFrame.LookVector * -2
	
	local pos = center + offset + Vector3.new(0,2,0)
	
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	
	root.Parent:PivotTo(CFrame.new(pos, center))
	
end

local function keepInside(bound)

	local root = getRoot()
	if not root then return end
	
	local dist = (root.Position - bound.Position).Magnitude
	
	if dist > stayRadius then
		teleportInside(bound)
	end
	
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	
end

local function chopTree(tree)

	local bound = tree:FindFirstChild("XZBounds")
	if not bound then return end
	
	teleportInside(bound)
	task.wait(0.15)
	
	repeat
		
		if not running then break end
		
		keepInside(bound)
		
		pcall(function()
			remote:InvokeServer()
		end)
		
		task.wait(delay)
		
	until tree:GetAttribute("Destroyed") == true or not running
	
end

task.spawn(function()

	while true do
		
		if running then
			
			for _,tree in pairs(treesFolder:GetChildren()) do
				
				if not running then break end
				
				if tree.Name == "InfectedTree" and not tree:GetAttribute("Destroyed") then
					
					chopTree(tree)
					
				end
				
			end
			
		end
		
		task.wait(0.05)
		
	end

end)

-- TOGGLE KEY (F)
UserInputService.InputBegan:Connect(function(input,gameProcessed)

	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.F then
		
		running = not running
		
		if running then
			print("Auto Chop ON")
		else
			print("Auto Chop OFF")
		end
		
	end
	
end)
