local function bindHover(btn, normalColor, hoverColor)
	btn.MouseEnter:Connect(function()
		tween(btn, {BackgroundColor3 = hoverColor}, 0.12)
	end)
	btn.MouseLeave:Connect(function()
		if btn == buyToggle then
			if buyRunning then
				tween(btn, {BackgroundColor3 = Color3.fromRGB(35, 85, 60)}, 0.12)
			else
				tween(btn, {BackgroundColor3 = normalColor}, 0.12)
			end
		elseif btn == chopToggle then
			if chopRunning then
				tween(btn, {BackgroundColor3 = Color3.fromRGB(35, 85, 60)}, 0.12)
			else
				tween(btn, {BackgroundColor3 = normalColor}, 0.12)
			end
		else
			tween(btn, {BackgroundColor3 = normalColor}, 0.12)
		end
	end)
end

