local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- remotes
local Knit = ReplicatedStorage.Packages.Knit.Services

local buyRemote = Knit.MerchantService.RF.BuyItem
local chopRemote = Knit.ChaosBreakablesService.RF.Clicked
local chestRemote = Knit.ChestService.RF.Open
local spinRemote = Knit.SpinnerService.RF.Spin
local giftRemote = Knit.GiftMachineService.RF.Claim
local refineryAddRemote = Knit.RefineryService.RF.AddAll
local refineryClaimRemote = Knit.RefineryService.RF.Claim

local treesFolder = workspace.GameObjects.ChaosBreakables.Axe

-- states
local buy=false
local chop=false
local chest=false
local chaosSpin=false
local gift=false
local refineryAdd=false
local refineryClaim=false
local egyptSpin=false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.new(0,260,0,360)
frame.Position = UDim2.new(0,50,0.3,0)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Active = true
frame.Draggable = true

local y = 10

local function makeToggle(text,callback)

	local btn = Instance.new("TextButton")
	btn.Parent = frame
	btn.Size = UDim2.new(0,220,0,30)
	btn.Position = UDim2.new(0,20,0,y)
	btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Text = text.." : OFF"

	local state = false

	btn.MouseButton1Click:Connect(function()
		state = not state
		btn.Text = text.." : "..(state and "ON" or "OFF")
		callback(state)
	end)

	y = y + 35

end

makeToggle("Auto Buy Atomic",function(v) buy=v end)
makeToggle("Auto Chop Axe",function(v) chop=v end)
makeToggle("Auto Atomic Chest",function(v) chest=v end)
makeToggle("Auto Chaos Spin",function(v) chaosSpin=v end)
makeToggle("Auto Gift Claim",function(v) gift=v end)
makeToggle("Auto Refinery Add",function(v) refineryAdd=v end)
makeToggle("Auto Refinery Claim",function(v) refineryClaim=v end)
