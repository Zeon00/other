    if not ui then return end

    local frames = ui:FindFirstChild("Frames")
    if not frames then return end

    local enchant = frames:FindFirstChild("EnchantWeapon")
    if not enchant then return end

    local main = enchant:FindFirstChild("Main")
    if not main then return end

    local craft = main:FindFirstChild("Craft")
    if not craft then return end

    local select = craft:FindFirstChild("Select")
    if not select then return end

    return select:FindFirstChild("ScrollingFrame")
end

