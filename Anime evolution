local function Toggle(name,pos,callback)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(1,-20,0,40)
    btn.Position = UDim2.new(0,10,0,40 + pos*45)
    btn.Text = name.." : OFF"

    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name.." : "..(state and "ON" or "OFF")
        callback(state)
    end)
end

Toggle("Auto Hit",0,function(v) AutoHit=v end)
Toggle("Auto Pet",1,function(v) AutoPet=v end)
Toggle("Auto Collect",2,function(v) AutoCollect=v end)
Toggle("Auto Train",3,function(v) AutoTrain=v end)
Toggle("TP Enemy",4,function(v) EnemyTP=v end)
Toggle("Auto Roll",5,function(v) AutoRoll=v end)

close.MouseButton1Click:Connect(function()
    gui:Destroy()
end)

mini.MouseButton1Click:Connect(function()
    main.Visible = false
    icon.Visible = true
end)

icon.MouseButton1Click:Connect(function()
    main.Visible = true
    icon.Visible = false
end)
