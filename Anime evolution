----------------------------------------------------------------

local function GetRoot()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char.HumanoidRootPart
    end
end

----------------------------------------------------------------
-- 🔥 GET ENEMY NAME DARI CLIENT (FIX UUID)
----------------------------------------------------------------

local function GetAllEnemyNames()
    local list = {}
    local enemies = workspace:FindFirstChild("Client") and workspace.Client:FindFirstChild("Enemies")
    if not enemies then return list end

    for _, v in pairs(enemies:GetDescendants()) do
        if v.Name and v.Parent and v.Parent.Name == "HumanoidRootPart" then
            local exist = false
            for _, n in pairs(list) do
                if n == v.Name then
                    exist = true
                    break
                end
            end
            if not exist then
                table.insert(list, v.Name)
            end
        end
    end

    table.sort(list)
    return list
end

----------------------------------------------------------------
-- 🔥 TARGET (FILTER NAME)
----------------------------------------------------------------

local function GetNearestEnemy()
    local root = GetRoot()
    if not root then return end

    local closest = nil
    local dist = math.huge

    local enemies = workspace.Server.Enemies

    for _, typeFolder in pairs({"World","Raid","WorldBoss"}) do
        local main = (typeFolder=="Raid" and enemies:FindFirstChild("Raids")) or enemies:FindFirstChild(typeFolder)

        if main then
            for _, world in pairs(main:GetChildren()) do
                for _, mob in pairs(world:GetChildren()) do

                    local hp = mob:GetAttribute("Health")
                    local died = mob:GetAttribute("Died")

                    if hp and hp > 0 and not died then

                        local valid = true
                        if UseSelected and SelectedEnemy then
                            if mob.Name ~= SelectedEnemy then
                                valid = false
                            end
                        end

                        if valid then
                            local pos = mob.Position or (mob:FindFirstChild("HumanoidRootPart") and mob.HumanoidRootPart.Position)

                            if pos then
                                local d = (root.Position - pos).Magnitude
                                if d < dist then
                                    dist = d
                                    closest = {Enemy = mob, Type = typeFolder}
                                end
                            end
                        end

                    end
                end
            end
        end
    end

    return closest
end

----------------------------------------------------------------
-- PET (TETAP)
----------------------------------------------------------------

local function GetPets()
    local pets = {}
    local folder = workspace.Server.Pets:FindFirstChild(tostring(player.UserId))

    if folder then
        for _, pet in pairs(folder:GetChildren()) do
            table.insert(pets, pet.Name)
        end
    end

    return pets
end

----------------------------------------------------------------
-- TP (TETAP)
----------------------------------------------------------------

local function TeleportToEnemy(mob)
    local root = GetRoot()
    if root then
        local pos = mob.Position or (mob:FindFirstChild("HumanoidRootPart") and mob.HumanoidRootPart.Position)
        if pos then
            root.CFrame = CFrame.lookAt(pos + Vector3.new(0,0,-3), pos)
        end
    end
end

----------------------------------------------------------------
-- MAIN LOOP (TETAP + FILTER)
----------------------------------------------------------------

task.spawn(function()
    while task.wait(0.5) do

        local target = GetNearestEnemy()

        if target then
            if EnemyTP and lastEnemy ~= target.Enemy then
                TeleportToEnemy(target.Enemy)
                lastEnemy = target.Enemy
            end

            for i = 1, HIT_MULTIPLIER do

                if AutoHit then
                    Remote:FireServer("Attack","Click",{
                        Type = target.Type,
                        Enemy = target.Enemy
                    })
                end

                if AutoPet then
                    for _, petID in pairs(GetPets()) do
                        Remote:FireServer("Attack","UnitAttack",{
                            {
                                Type = target.Type,
                                Enemy = target.Enemy
                            },
                            petID
                        })
                    end
                end

            end
        end

        if AutoTrain then
            for i = 1, HIT_MULTIPLIER do
                Remote:FireServer("Attack","Click",{})
            end
        end

    end
end)

