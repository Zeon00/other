task.spawn(function()
    while task.wait(0.01) do
        if AutoCollect then
            local drops = workspace:FindFirstChild("Drops")
            if drops then
                for _, d in pairs(drops:GetDescendants()) do
                    if d:IsA("BasePart") then
                        Remote:FireServer("Drops","Collect", d.Name)
                    end
                end
            end
        end
    end
end)

