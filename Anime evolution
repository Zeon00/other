local function GetPets()
    local pets = {}
    local folder = workspace.Server.Pets:FindFirstChild(tostring(player.UserId))

    if folder then
        for _, pet in pairs(folder:GetChildren()) do
            table.insert(pets, pet.Name)
        end
    end

    return pets
end

----------------------------------------------------------------
-- 🔥 TP FIX FULL (AUTO RAID / WORLD)
----------------------------------------------------------------
local lastTPTime = 0

local function TeleportToEnemy(mob, enemyType)
    local root = GetRoot()
    if not root or not mob then return end

    local hrp = mob:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = hrp.Position
    if not pos then return end

    -- ❌ anti void
    if pos.Y < -5 then return end

    -- ❌ limit distance
    local dist = (root.Position - pos).Magnitude
    if dist > TP_DISTANCE then return end

    -- ❌ anti spam
    if tick() - lastTPTime < 0.2 then return end
    lastTPTime = tick()

    -- ❌ skip kalau musuh lagi dash
    if hrp.AssemblyLinearVelocity.Magnitude > 80 then
        return
    end

    -- 🔥 DETECT RAID
    local isRaid = enemyType and string.find(enemyType, "Raid")

    -- 🔥 JARAK BELAKANG
    local backDistance = isRaid and 20 or 10
    local height = isRaid and 6 or 3

    -- 🔥 HITUNG POSISI BELAKANG MUSUH
    local look = hrp.CFrame.LookVector
    local behindPos = pos - (look * backDistance) + Vector3.new(0, height, 0)

    -- 🔥 RESET VELOCITY
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    -- 🔥 TP + HADAP KE MUSUH
    pcall(function()
        root.CFrame = CFrame.lookAt(behindPos, pos)
    end)
end
----------------------------------------------------------------
-- ROLL MAP (TETAP)
----------------------------------------------------------------

local function GetCurrentMap()
    local enemies = workspace.Server.Enemies:FindFirstChild("World")
    if not enemies then return LastMap end

    for _, map in pairs(enemies:GetChildren()) do
        if #map:GetChildren() > 0 then
            LastMap = map.Name
            return map.Name
        end
    end

    return LastMap
end

