local function FindWorldBoss()
    local folder = workspace.Server.Enemies:FindFirstChild("WorldBoss")
    if not folder then return end

    for _, mapFolder in pairs(folder:GetChildren()) do
        for _, boss in pairs(mapFolder:GetChildren()) do

            local hp = boss:GetAttribute("Health")
            local died = boss:GetAttribute("Died")

            if hp and hp > 0 and not died then
                return boss, mapFolder.Name
            end
        end
    end
end

local function GetClientBoss()
    local folder = workspace.Client:FindFirstChild("Enemies")
    if not folder then return end

    local wb = folder:FindFirstChild("WorldBoss")
    if not wb then return end

    for _, v in pairs(wb:GetDescendants()) do
        if v:IsA("BasePart") then
            return v
        end
    end
end
