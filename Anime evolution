local function RefreshEnemyList()
    for _,v in pairs(right:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    for _,name in pairs(GetAllEnemyNames()) do
        local b = Instance.new("TextButton", right)
        b.Size = UDim2.new(1,-10,0,32)
        b.Position = UDim2.new(0,5,0,0)
        b.Font = Enum.Font.GothamMedium
        b.TextSize = 13
        b.Text = name
        b.AutoButtonColor = false
        Round(b,8)

        local function Update()
            if SelectedEnemies[name] then
                b.BackgroundColor3 = Color3.fromRGB(40,120,40)
                b.TextColor3 = Color3.new(1,1,1)
            else
                b.BackgroundColor3 = Color3.fromRGB(22,22,22)
                b.TextColor3 = Color3.fromRGB(200,200,200)
            end
        end

        Update()

        b.MouseButton1Click:Connect(function()
            if SelectedEnemies[name] then
                SelectedEnemies[name] = nil
            else
                SelectedEnemies[name] = true
            end
            Update()
        end)

        b.MouseEnter:Connect(function()
            if not SelectedEnemies[name] then
                b.BackgroundColor3 = Color3.fromRGB(35,35,35)
            end
        end)

        b.MouseLeave:Connect(Update)
    end
end

RefreshEnemyList()

