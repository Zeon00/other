--// SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local Remote = RS:WaitForChild("Bridge")

-- WAIT CHAR
local function GetRoot()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char.HumanoidRootPart
    end
end

-- STATES
local AutoHit = false
local AutoPet = false
local AutoCollect = false
local AutoTrain = false
local EnemyTP = false
local AutoRoll = false

local HIT_MULTIPLIER = 25
local lastEnemy = nil

----------------------------------------------------------------
-- GET ENEMY
----------------------------------------------------------------

local function GetNearestEnemy()
    local root = GetRoot()
    if not root then return nil end

    local closest = nil
    local dist = math.huge

    local enemies = workspace:FindFirstChild("Server")
    if enemies then
        enemies = enemies:FindFirstChild("Enemies")
    end

    if enemies then
        for _, typeFolder in pairs({"World","Raids","WorldBoss"}) do
            local main = enemies:FindFirstChild(typeFolder)
            if main then
                for _, world in pairs(main:GetChildren()) do
                    for _, mob in pairs(world:GetChildren()) do
                        if mob:GetAttribute("Health") and mob:GetAttribute("Health") > 0 then
                            
                            local hrp = mob:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local d = (root.Position - hrp.Position).Magnitude
                                if d < dist then
                                    dist = d
                                    closest = {
                                        Enemy = mob,
                                        Type = typeFolder
                                    }
                                end
                            end

                        end
                    end
                end
            end
        end
    end

    return closest
end

----------------------------------------------------------------
-- PETS
----------------------------------------------------------------

local function GetPets()
    local pets = {}
    local folder = workspace:FindFirstChild("Server")

    if folder then
        folder = folder:FindFirstChild("Pets")
    end

    if folder then
        folder = folder:FindFirstChild(tostring(player.UserId))
    end

    if folder then
        for _, pet in pairs(folder:GetChildren()) do
            table.insert(pets, pet.Name)
        end
    end

    return pets
end

----------------------------------------------------------------
-- TP
----------------------------------------------------------------

local function TeleportToEnemy(mob)
    local root = GetRoot()
    if root then
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hrp then
            root.CFrame = CFrame.new(hrp.Position + Vector3.new(0,0,-3))
        end
    end
end

----------------------------------------------------------------
-- MAIN LOOP
----------------------------------------------------------------

task.spawn(function()
    while task.wait(0.08) do

        local target = GetNearestEnemy()

        if target then

            if EnemyTP then
                if lastEnemy ~= target.Enemy then
                    TeleportToEnemy(target.Enemy)
                    lastEnemy = target.Enemy
                end
            end

            if AutoHit or AutoPet then
                for i = 1, HIT_MULTIPLIER do

                    if AutoHit then
                        Remote:FireServer("Attack","Click", target)
                    end

                    if AutoPet then
                        local pets = GetPets()
                        for _, petID in pairs(pets) do
                            Remote:FireServer("Attack","UnitAttack", {
                                target,
                                petID
                            })
                        end
                    end

                end
            end

        end

        if AutoTrain then
            for i = 1, HIT_MULTIPLIER do
                Remote:FireServer("Attack","Click",{})
            end
        end

    end
end)

----------------------------------------------------------------
-- AUTO COLLECT
----------------------------------------------------------------

task.spawn(function()
    while task.wait(0.12) do
        if AutoCollect then

            local root = GetRoot()
            if root then

                local debris = workspace:FindFirstChild("Debris")
                if debris then

                    for _, drop in pairs(debris:GetDescendants()) do
                        if drop:IsA("BasePart") then
                            drop.CFrame = root.CFrame * CFrame.new(0,0,-2)
                            Remote:FireServer("Drops","Collect", drop.Name)
                        end
                    end

                end
            end

        end
    end
end)

----------------------------------------------------------------
-- AUTO ROLL
----------------------------------------------------------------

task.spawn(function()
    while task.wait(0.2) do
        if AutoRoll then
            Remote:FireServer("Stars","Roll",{
                Map = "Fiery World",
                Type = "Multi"
            })
        end
    end
end)

