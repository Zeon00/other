-- 🔥 MAP HASH (DETECT PERUBAHAN MAP)
local function GetMapHash()
    local enemies = workspace:FindFirstChild("Client") and workspace.Client:FindFirstChild("Enemies")
    if not enemies then return "" end

    local str = ""
    for _, v in pairs(enemies:GetDescendants()) do
        str = str .. v.Name
    end
    return str
end

local currentHash = GetMapHash()

-- 🔥 REFRESH LIST FUNCTION
local function RefreshEnemyList()
    for _, v in pairs(right:GetChildren()) do
        if v:IsA("TextButton") then
            v:Destroy()
        end
    end

    local list = GetAllEnemyNames()

    for _, name in pairs(list) do
        local b = Instance.new("TextButton", right)
        b.Size = UDim2.new(1,0,0,30)
        b.Text = name

        b.MouseButton1Click:Connect(function()
            SelectedEnemy = name
        end)
    end

    right.CanvasSize = UDim2.new(0,0,0,#list * 30)
end

