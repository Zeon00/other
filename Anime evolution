-- AUTO REFRESH MAP
local function GetMapHash()
    local enemies = workspace:FindFirstChild("Client") and workspace.Client:FindFirstChild("Enemies")
    if not enemies then return "" end
    local str = ""
    for _,v in pairs(enemies:GetDescendants()) do
        str = str..v.Name
    end
    return str
end

local currentHash = GetMapHash()

task.spawn(function()
    while task.wait(10) do
        local newHash = GetMapHash()
        if newHash ~= currentHash then
            currentHash = newHash
            RefreshEnemyList()
        end
    end
end)
