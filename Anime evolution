--// STATES
local AutoHit = false
local AutoPet = false
local AutoCollect = false
local AutoTrain = false
local EnemyTP = false
local AutoRoll = false
local AntiAFK = false

-- 🔥 CRYSTAL
local CrystalHit = false
local CrystalPet = false

local lastEnemy = nil
local HIT_MULTIPLIER = 2

----------------------------------------------------------------
-- CORE
----------------------------------------------------------------

local function GetRoot()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char.HumanoidRootPart
    end
end

-- 🔥 AMBIL SEMUA CRYSTAL (SERVER SIDE FIX)
local function GetCrystalEnemies()
    local list = {}

    local raid = workspace.Server.Enemies.Raids:FindFirstChild("Raid_Crystal")
    if not raid then return list end

    for _, mob in pairs(raid:GetChildren()) do
        if mob:GetAttribute("Health") and mob:GetAttribute("Health") > 0 then
            table.insert(list, mob)
        end
    end

    return list
end

-- NORMAL ENEMY
local function GetNearestEnemy()
    local root = GetRoot()
    if not root then return end

    local closest = nil
    local dist = math.huge

    for _, typeFolder in pairs({"World","Raids","WorldBoss"}) do
        local main = workspace.Server.Enemies:FindFirstChild(typeFolder)
        if main then
            for _, world in pairs(main:GetChildren()) do
                for _, mob in pairs(world:GetChildren()) do

                    local hp = mob:GetAttribute("Health")
                    if hp and hp > 0 then
                        local pos = mob.Position or (mob:FindFirstChild("HumanoidRootPart") and mob.HumanoidRootPart.Position)

                        if pos then
                            local d = (root.Position - pos).Magnitude
                            if d < dist then
                                dist = d
                                closest = {
                                    Enemy = mob,
                                    Type = typeFolder
                                }
                            end
                        end
                    end

                end
            end
        end
    end

    return closest
end

local function GetPets()
    local pets = {}
    local folder = workspace.Server.Pets:FindFirstChild(tostring(player.UserId))

    if folder then
        for _, pet in pairs(folder:GetChildren()) do
            table.insert(pets, pet.Name)
        end
    end

    return pets
end

----------------------------------------------------------------
-- TP
----------------------------------------------------------------

local function TeleportToEnemy(mob)
    local root = GetRoot()
    if root then
        local pos = mob.Position or (mob:FindFirstChild("HumanoidRootPart") and mob.HumanoidRootPart.Position)
        if pos then
            local offset = Vector3.new(0,0,-3)
            local myPos = pos + offset
            root.CFrame = CFrame.lookAt(myPos, pos)
            root.Velocity = Vector3.new(0,0,0)
        end
    end
end

----------------------------------------------------------------
-- MAIN LOOP
----------------------------------------------------------------

task.spawn(function()
    while task.wait(0.08) do

        -- 🔥 CRYSTAL MODE (HIT SEMUA)
        if CrystalHit or CrystalPet then
            local crystals = GetCrystalEnemies()

            for _, mob in pairs(crystals) do

                if EnemyTP then
                    if lastEnemy ~= mob then
                        TeleportToEnemy(mob)
                        lastEnemy = mob
                    end
                end

                for i = 1, HIT_MULTIPLIER do

                    if CrystalHit then
                        Remote:FireServer("Attack","Click", {
                            Type = "Raids",
                            Enemy = mob
                        })
                    end

                    if CrystalPet then
                        for _, petID in pairs(GetPets()) do
                            Remote:FireServer("Attack","UnitAttack", {
                                {
                                    Type = "Raids",
                                    Enemy = mob
                                },
                                petID
                            })
                        end
                    end

                end
            end

        else
            -- 🔥 NORMAL MODE
            local target = GetNearestEnemy()

            if target then

                if EnemyTP then
                    if lastEnemy ~= target.Enemy then
                        TeleportToEnemy(target.Enemy)
                        lastEnemy = target.Enemy
                    end
                end

                for i = 1, HIT_MULTIPLIER do

                    if AutoHit then
                        Remote:FireServer("Attack","Click", {
                            Type = target.Type,
                            Enemy = target.Enemy
                        })
                    end

                    if AutoPet then
                        for _, petID in pairs(GetPets()) do
                            Remote:FireServer("Attack","UnitAttack", {
                                {
                                    Type = target.Type,
                                    Enemy = target.Enemy
                                },
                                petID
                            })
                        end
                    end

                end
            end
        end

        -- TRAIN
        if AutoTrain then
            for i = 1, HIT_MULTIPLIER do
                Remote:FireServer("Attack","Click",{})
            end
        end

    end
end)

